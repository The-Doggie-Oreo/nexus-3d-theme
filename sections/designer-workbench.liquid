{%- comment -%}
  NEXUS-3D  ·  DESIGNER WORKBENCH — Linen & Steel
  Pill-shaped Steel Blue trigger, M3 slide-up panel
{%- endcomment -%}

{%- liquid
  assign wb_enabled = section.settings.enable_workbench
-%}

{%- if wb_enabled -%}
<aside class="nexus-workbench" data-section-id="{{ section.id }}">

  {%- comment -%} Trigger Pill {%- endcomment -%}
  <button type="button" class="nexus-workbench__trigger" id="WorkbenchTrigger" aria-label="Open Designer Workbench" aria-expanded="false">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    <span>Design Help</span>
  </button>

  {%- comment -%} Workbench Panel {%- endcomment -%}
  <div class="nexus-workbench__panel" id="WorkbenchPanel" aria-hidden="true">
    <div class="nexus-workbench__panel-head">
      <div>
        <h3 style="font-family:var(--nx-font-heading); font-weight:800; font-size:1.05rem; color:var(--nx-dark); margin:0;">Designer Workbench</h3>
        <p style="font-family:var(--nx-font-mono); font-size:11px; text-transform:uppercase; color:var(--nx-body); opacity:.5; margin:4px 0 0;">{{ section.settings.wb_subtitle }}</p>
      </div>
      <button type="button" class="nexus-workbench__close" id="WorkbenchClose" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="nexus-workbench__body">
      {%- comment -%} Upload Section {%- endcomment -%}
      <div class="nexus-workbench__upload" id="WorkbenchDropzone">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <p style="font-family:var(--nx-font-heading); font-weight:700; color:var(--nx-dark); margin:8px 0 4px;">Drop your 3D file</p>
        <p style="font-size:.8rem; color:var(--nx-body); opacity:.5;">STL · OBJ · STEP — Max 50 MB</p>
      </div>

      {%- comment -%} Quick Options {%- endcomment -%}
      <div class="nexus-workbench__options">
        <label class="nexus-workbench__field">
          <span>Material</span>
          <select style="font-family:var(--nx-font-mono); font-size:13px; padding:10px 14px; background:var(--nx-bg); color:var(--nx-dark); border:1px solid var(--nx-outline); border-radius:var(--nx-radius-pill); width:100%; appearance:none; cursor:pointer;">
            <option>PLA — Standard</option>
            <option>Resin — High Detail</option>
            <option>Nylon — Durable</option>
            <option>PETG — Flexible</option>
          </select>
        </label>
        <label class="nexus-workbench__field">
          <span>Quality</span>
          <select style="font-family:var(--nx-font-mono); font-size:13px; padding:10px 14px; background:var(--nx-bg); color:var(--nx-dark); border:1px solid var(--nx-outline); border-radius:var(--nx-radius-pill); width:100%; appearance:none; cursor:pointer;">
            <option>Standard — 0.2mm</option>
            <option>High — 0.1mm</option>
            <option>Ultra — 0.05mm</option>
          </select>
        </label>
      </div>

      <button type="button" class="nexus-btn nexus-btn--primary nexus-btn--full" style="margin-top:16px;">Get Instant Quote</button>
    </div>
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  <div class="nexus-workbench__overlay" id="WorkbenchOverlay"></div>
</aside>

<style>
  .nexus-workbench__trigger {
    position: fixed; bottom: 24px; right: 24px; z-index: 999;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    border: none; border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-heading); font-weight: 700;
    font-size: .85rem; cursor: pointer;
    box-shadow: var(--nx-shadow-lg);
    transition: transform .25s, box-shadow .25s, background .2s;
  }
  .nexus-workbench__trigger:hover {
    transform: translateY(-2px);
    box-shadow: var(--nx-shadow-xl);
    background: var(--nx-primary-hover);
  }

  .nexus-workbench__panel {
    position: fixed; bottom: 0; right: 24px; z-index: 1000;
    width: 380px; max-height: 80vh;
    background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-bottom: none;
    border-radius: var(--nx-radius-xl) var(--nx-radius-xl) 0 0;
    box-shadow: var(--nx-shadow-xl);
    transform: translateY(100%);
    transition: transform .35s cubic-bezier(.4, 0, .2, 1);
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  .nexus-workbench__panel.is-open { transform: translateY(0); }

  .nexus-workbench__panel-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid var(--nx-outline);
  }
  .nexus-workbench__close {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; border: 1px solid var(--nx-outline);
    background: var(--nx-surface); color: var(--nx-dark);
    cursor: pointer; transition: background .2s;
  }
  .nexus-workbench__close:hover { background: var(--nx-primary); color: var(--nx-on-primary); }

  .nexus-workbench__body { padding: 24px; overflow-y: auto; flex: 1; }

  .nexus-workbench__upload {
    border: 2px dashed var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    padding: 32px; text-align: center;
    transition: border-color .2s, background .2s;
    cursor: pointer;
  }
  .nexus-workbench__upload:hover,
  .nexus-workbench__upload.is-drag-over {
    border-color: var(--nx-primary);
    background: var(--nx-primary-04);
  }

  .nexus-workbench__options { display: flex; flex-direction: column; gap: 12px; margin-top: 20px; }
  .nexus-workbench__field span {
    display: block; font-family: var(--nx-font-mono);
    font-size: 10px; text-transform: uppercase;
    letter-spacing: .06em; color: var(--nx-body);
    opacity: .55; margin-bottom: 6px;
  }

  .nexus-workbench__overlay {
    position: fixed; inset: 0; z-index: 998;
    background: rgba(0,0,0,.2);
    opacity: 0; pointer-events: none;
    transition: opacity .3s;
  }
  .nexus-workbench__overlay.is-open { opacity: 1; pointer-events: all; }

  @media (max-width: 640px) {
    .nexus-workbench__panel { width: calc(100% - 32px); right: 16px; }
    .nexus-workbench__trigger { bottom: 16px; right: 16px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var trigger = document.getElementById('WorkbenchTrigger');
    var panel   = document.getElementById('WorkbenchPanel');
    var closeBtn = document.getElementById('WorkbenchClose');
    var overlay = document.getElementById('WorkbenchOverlay');
    if (!trigger || !panel) return;

    function open() { panel.classList.add('is-open'); overlay.classList.add('is-open'); trigger.style.display = 'none'; trigger.setAttribute('aria-expanded','true'); }
    function close() { panel.classList.remove('is-open'); overlay.classList.remove('is-open'); trigger.style.display = ''; trigger.setAttribute('aria-expanded','false'); }

    trigger.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    var dropzone = document.getElementById('WorkbenchDropzone');
    if (dropzone) {
      ['dragenter','dragover'].forEach(function(e){ dropzone.addEventListener(e, function(ev){ ev.preventDefault(); dropzone.classList.add('is-drag-over'); }); });
      ['dragleave','drop'].forEach(function(e){ dropzone.addEventListener(e, function(){ dropzone.classList.remove('is-drag-over'); }); });
    }
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "Designer Workbench",
  "tag": "aside",
  "class": "nexus-workbench-wrapper",
  "settings": [
    { "type": "checkbox", "id": "enable_workbench", "label": "Enable Workbench", "default": true },
    { "type": "text", "id": "wb_subtitle", "label": "Subtitle", "default": "Quick File Check" }
  ],
  "templates": ["index", "product", "collection", "page"]
}
{% endschema %}
