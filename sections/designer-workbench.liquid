{%- comment -%}
  NEXUS-3D  ·  DESIGNER'S WORKBENCH
  Integrated Messenger / Shopify Inbox portal
{%- endcomment -%}

<aside class="nexus-workbench" id="NexusWorkbench" aria-label="Designer's Workbench">
  {%- comment -%} Toggle trigger {%- endcomment -%}
  <button class="nexus-workbench__trigger" id="WorkbenchToggle" aria-expanded="false" aria-controls="WorkbenchPanel">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
    </svg>
    <span class="nexus-workbench__trigger-badge"></span>
  </button>

  {%- comment -%} Panel {%- endcomment -%}
  <div class="nexus-workbench__panel" id="WorkbenchPanel" aria-hidden="true">
    <div class="nexus-workbench__panel-header">
      <div class="nexus-workbench__panel-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 20h9"/>
          <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        Designer's Workbench
      </div>
      <button class="nexus-workbench__close" id="WorkbenchClose" aria-label="Close panel">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="nexus-workbench__panel-body">
      <p class="nexus-workbench__intro">{{ settings.workbench_intro_text }}</p>

      {%- comment -%} Project Status Cards {%- endcomment -%}
      {%- if customer -%}
        <div class="nexus-workbench__status-section">
          <h4 class="nexus-workbench__section-title">Your Projects</h4>
          {%- for order in customer.orders limit: 3 -%}
            <div class="nexus-workbench__project-card">
              <div class="nexus-workbench__project-name">{{ order.name }}</div>
              <div class="nexus-workbench__project-status">
                <span class="nexus-workbench__status-dot" data-fulfillment="{{ order.fulfillment_status }}"></span>
                {{ order.fulfillment_status | default: 'Processing' }}
              </div>
              <div class="nexus-workbench__project-date">{{ order.created_at | date: "%b %d, %Y" }}</div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Quick Contact Form {%- endcomment -%}
      <div class="nexus-workbench__contact">
        <h4 class="nexus-workbench__section-title">Send a Message</h4>
        <form action="{{ routes.root_url }}" method="post" class="nexus-workbench__form">
          <input type="hidden" name="form_type" value="contact">
          <input type="hidden" name="utf8" value="✓">
          <textarea
            name="contact[body]"
            class="nexus-workbench__textarea"
            placeholder="Describe your project or ask about an order..."
            rows="3"
            required
          ></textarea>
          {%- unless customer -%}
            <input
              type="email"
              name="contact[email]"
              class="nexus-workbench__input"
              placeholder="your@email.com"
              required
            >
          {%- endunless -%}
          <button type="submit" class="nexus-btn nexus-btn--primary nexus-btn--full">
            Send to Studio
          </button>
        </form>
      </div>
    </div>
  </div>
</aside>

<style>
  /* ── M3 Trigger FAB ── */
  .nexus-workbench__trigger {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    width: 56px; height: 56px;
    border-radius: var(--m3-radius-lg);
    background: var(--m3-primary-container);
    color: var(--m3-on-primary-container);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--m3-elevation-3);
    transition: transform .2s cubic-bezier(.2, 0, 0, 1), box-shadow .2s;
  }
  .nexus-workbench__trigger:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 40px rgba(208,188,255,.35);
  }
  .nexus-workbench__trigger-badge {
    position: absolute;
    top: 4px; right: 4px;
    width: 10px; height: 10px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid var(--m3-primary-container);
  }

  /* ── M3 Panel ── */
  .nexus-workbench__panel {
    position: fixed;
    bottom: 96px;
    right: 24px;
    z-index: 998;
    width: 380px;
    max-height: 520px;
    background: var(--m3-surface-container-high);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-xl);
    box-shadow: var(--m3-elevation-3);
    display: flex;
    flex-direction: column;
    transform: translateY(16px);
    opacity: 0;
    pointer-events: none;
    transition: all .3s cubic-bezier(.22,1,.36,1);
  }
  .nexus-workbench__panel.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .nexus-workbench__panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 20px;
    border-bottom: 1px solid var(--m3-outline-variant);
  }
  .nexus-workbench__panel-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--nexus-font-heading);
    font-weight: 700;
    font-size: .95rem;
    color: #fff;
  }
  .nexus-workbench__close {
    background: none; border: none;
    color: var(--m3-on-surface-variant); opacity: .5;
    cursor: pointer; transition: opacity .2s;
    width: 32px; height: 32px;
    border-radius: var(--m3-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nexus-workbench__close:hover { opacity: 1; background: rgba(208,188,255,.08); }

  .nexus-workbench__panel-body {
    padding: 20px;
    overflow-y: auto;
    flex: 1;
  }
  .nexus-workbench__intro {
    font-size: .85rem;
    color: var(--m3-on-surface-variant);
    margin: 0 0 20px;
    line-height: 1.5;
  }
  .nexus-workbench__section-title {
    font-family: var(--nexus-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--nexus-accent);
    margin: 0 0 12px;
  }

  .nexus-workbench__project-card {
    padding: 14px;
    background: var(--m3-surface-container);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-lg);
    margin-bottom: 8px;
    transition: box-shadow .2s;
  }
  .nexus-workbench__project-card:hover {
    box-shadow: var(--m3-elevation-1);
  }
  .nexus-workbench__project-name { font-weight: 600; color: #fff; font-size: .85rem; }
  .nexus-workbench__project-status {
    display: flex; align-items: center; gap: 6px;
    font-size: .8rem; color: var(--m3-on-surface-variant);
    margin-top: 4px; text-transform: capitalize;
  }
  .nexus-workbench__status-dot {
    width: 6px; height: 6px; border-radius: 50%; background: #eab308;
  }
  .nexus-workbench__status-dot[data-fulfillment="fulfilled"] { background: #22c55e; }
  .nexus-workbench__status-dot[data-fulfillment="partial"]   { background: #f97316; }
  .nexus-workbench__project-date {
    font-family: var(--nexus-font-mono); font-size: 10px;
    color: var(--m3-on-surface-variant); opacity: .4; margin-top: 4px;
  }

  .nexus-workbench__status-section { margin-bottom: 24px; }

  .nexus-workbench__textarea,
  .nexus-workbench__input {
    width: 100%;
    padding: 10px 14px;
    background: var(--m3-surface-container);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-lg);
    color: var(--nexus-text);
    font-family: var(--nexus-font-body);
    font-size: .85rem;
    margin-bottom: 10px;
    box-sizing: border-box;
    transition: border-color .2s, box-shadow .2s;
  }
  .nexus-workbench__textarea:focus,
  .nexus-workbench__input:focus {
    outline: none;
    border-color: var(--nexus-accent);
    box-shadow: 0 0 0 3px rgba(208,188,255,.12);
  }

  @media (max-width: 768px) {
    .nexus-workbench__trigger { bottom: 80px; right: 16px; }
    .nexus-workbench__panel {
      right: 8px; left: 8px;
      width: auto; bottom: 144px;
    }
  }
</style>

<script>
  (function () {
    var toggle = document.getElementById('WorkbenchToggle');
    var panel  = document.getElementById('WorkbenchPanel');
    var close  = document.getElementById('WorkbenchClose');
    if (!toggle || !panel) return;

    toggle.addEventListener('click', function () {
      var open = panel.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open);
      panel.setAttribute('aria-hidden', !open);
    });
    if (close) {
      close.addEventListener('click', function () {
        panel.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        panel.setAttribute('aria-hidden', 'true');
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Designer Workbench",
  "class": "nexus-workbench-section",
  "settings": []
}
{% endschema %}
