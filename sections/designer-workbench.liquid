{%- comment -%}
  NEXUS-3D  ·  CONTACT WIDGET — Linen & Steel
  Pill-shaped trigger → slide-up contact panel
  Uses real mailto: links and Shopify contact form concepts
{%- endcomment -%}

{%- liquid
  assign wb_enabled = section.settings.enable_workbench
-%}

{%- if wb_enabled -%}
<aside class="nexus-workbench" data-section-id="{{ section.id }}">

  {%- comment -%} Trigger Pill {%- endcomment -%}
  <button type="button" class="nexus-workbench__trigger" id="WorkbenchTrigger" aria-label="Contact us" aria-expanded="false">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
    <span>Contact Us</span>
  </button>

  {%- comment -%} Panel {%- endcomment -%}
  <div class="nexus-workbench__panel" id="WorkbenchPanel" aria-hidden="true">
    <div class="nexus-workbench__panel-head">
      <div>
        <h3 style="font-family:var(--nx-font-heading); font-weight:800; font-size:1.05rem; color:var(--nx-dark); margin:0;">Get In Touch</h3>
        <p style="font-family:var(--nx-font-mono); font-size:11px; text-transform:uppercase; color:var(--nx-body); opacity:.5; margin:4px 0 0;">{{ section.settings.wb_subtitle }}</p>
      </div>
      <button type="button" class="nexus-workbench__close" id="WorkbenchClose" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="nexus-workbench__body">

      {%- comment -%} Contact Methods {%- endcomment -%}
      {%- if section.settings.contact_email != blank -%}
        <a href="mailto:{{ section.settings.contact_email }}" class="nexus-workbench__method">
          <div class="nexus-workbench__method-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <span class="nexus-workbench__method-label">Email Us</span>
            <span class="nexus-workbench__method-value">{{ section.settings.contact_email }}</span>
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:auto; opacity:.3;"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.contact_phone != blank -%}
        <a href="tel:{{ section.settings.contact_phone | remove: ' ' }}" class="nexus-workbench__method">
          <div class="nexus-workbench__method-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <span class="nexus-workbench__method-label">Call Us</span>
            <span class="nexus-workbench__method-value">{{ section.settings.contact_phone }}</span>
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:auto; opacity:.3;"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {%- endif -%}

      {%- comment -%} Quick Message Form {%- endcomment -%}
      <div class="nexus-workbench__divider">
        <span>Or send a quick message</span>
      </div>

      <form action="/contact#contact_form" method="post" class="nexus-workbench__form">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="utf8" value="✓">

        <div class="nexus-workbench__field-group">
          <label class="nexus-workbench__field-label" for="WbName">Name</label>
          <input type="text" id="WbName" name="contact[name]" required placeholder="Your name" class="nexus-workbench__input">
        </div>

        <div class="nexus-workbench__field-group">
          <label class="nexus-workbench__field-label" for="WbEmail">Email</label>
          <input type="email" id="WbEmail" name="contact[email]" required placeholder="you@example.com" class="nexus-workbench__input">
        </div>

        <div class="nexus-workbench__field-group">
          <label class="nexus-workbench__field-label" for="WbMessage">Message</label>
          <textarea id="WbMessage" name="contact[body]" rows="3" required placeholder="Describe your project..." class="nexus-workbench__textarea"></textarea>
        </div>

        <button type="submit" class="nexus-btn nexus-btn--primary nexus-btn--full">Send Message</button>
      </form>

      {%- if section.settings.response_note != blank -%}
        <p style="font-family:var(--nx-font-mono); font-size:10px; text-align:center; color:var(--nx-body); opacity:.4; margin:12px 0 0; text-transform:uppercase; letter-spacing:.04em;">
          {{ section.settings.response_note }}
        </p>
      {%- endif -%}
    </div>
  </div>

  <div class="nexus-workbench__overlay" id="WorkbenchOverlay"></div>
</aside>

<style>
  .nexus-workbench__trigger {
    position: fixed; bottom: 24px; right: 24px; z-index: 999;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 24px;
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    border: none; border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-heading); font-weight: 700;
    font-size: .85rem; cursor: pointer;
    box-shadow: var(--nx-shadow-lg);
    transition: transform .25s, box-shadow .25s, background .2s;
  }
  .nexus-workbench__trigger:hover {
    transform: translateY(-2px);
    box-shadow: var(--nx-shadow-xl);
    background: var(--nx-primary-hover);
  }

  .nexus-workbench__panel {
    position: fixed; bottom: 0; right: 24px; z-index: 1000;
    width: 380px; max-height: 85vh;
    background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-bottom: none;
    border-radius: var(--nx-radius-xl) var(--nx-radius-xl) 0 0;
    box-shadow: var(--nx-shadow-xl);
    transform: translateY(100%);
    transition: transform .35s cubic-bezier(.4, 0, .2, 1);
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  .nexus-workbench__panel.is-open { transform: translateY(0); }

  .nexus-workbench__panel-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid var(--nx-outline);
  }
  .nexus-workbench__close {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; border: 1px solid var(--nx-outline);
    background: var(--nx-surface); color: var(--nx-dark);
    cursor: pointer; transition: background .2s;
  }
  .nexus-workbench__close:hover { background: var(--nx-primary); color: var(--nx-on-primary); }

  .nexus-workbench__body { padding: 24px; overflow-y: auto; flex: 1; }

  /* Contact methods */
  .nexus-workbench__method {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 16px;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    text-decoration: none; color: inherit;
    transition: border-color .2s, box-shadow .2s;
    margin-bottom: 10px;
  }
  .nexus-workbench__method:hover {
    border-color: var(--nx-primary);
    box-shadow: var(--nx-shadow-sm);
  }
  .nexus-workbench__method-icon {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: var(--nx-primary-06);
    border-radius: var(--nx-radius-md);
    flex-shrink: 0;
  }
  .nexus-workbench__method-label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .55;
  }
  .nexus-workbench__method-value {
    display: block;
    font-family: var(--nx-font-heading); font-weight: 700;
    font-size: .85rem; color: var(--nx-dark);
  }

  /* Divider */
  .nexus-workbench__divider {
    display: flex; align-items: center; gap: 12px;
    margin: 18px 0 16px;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .4;
  }
  .nexus-workbench__divider::before,
  .nexus-workbench__divider::after {
    content: ''; flex: 1;
    height: 1px; background: var(--nx-outline);
  }

  /* Form */
  .nexus-workbench__form { display: flex; flex-direction: column; gap: 12px; }
  .nexus-workbench__field-group {}
  .nexus-workbench__field-label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .55; margin-bottom: 4px;
  }
  .nexus-workbench__input {
    width: 100%; padding: 10px 14px;
    background: var(--nx-surface); color: var(--nx-dark);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-body); font-size: .85rem;
    transition: border-color .2s;
  }
  .nexus-workbench__input:focus,
  .nexus-workbench__textarea:focus {
    outline: none; border-color: var(--nx-primary);
    box-shadow: 0 0 0 3px var(--nx-primary-10);
  }
  .nexus-workbench__textarea {
    width: 100%; padding: 10px 14px;
    background: var(--nx-surface); color: var(--nx-dark);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    font-family: var(--nx-font-body); font-size: .85rem;
    resize: vertical; transition: border-color .2s;
  }

  .nexus-workbench__overlay {
    position: fixed; inset: 0; z-index: 998;
    background: rgba(0,0,0,.2);
    opacity: 0; pointer-events: none;
    transition: opacity .3s;
  }
  .nexus-workbench__overlay.is-open { opacity: 1; pointer-events: all; }

  @media (max-width: 640px) {
    .nexus-workbench__panel { width: calc(100% - 32px); right: 16px; }
    .nexus-workbench__trigger { bottom: 16px; right: 16px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var trigger = document.getElementById('WorkbenchTrigger');
    var panel   = document.getElementById('WorkbenchPanel');
    var closeBtn = document.getElementById('WorkbenchClose');
    var overlay = document.getElementById('WorkbenchOverlay');
    if (!trigger || !panel) return;

    function open() { panel.classList.add('is-open'); overlay.classList.add('is-open'); trigger.style.display = 'none'; trigger.setAttribute('aria-expanded','true'); }
    function close() { panel.classList.remove('is-open'); overlay.classList.remove('is-open'); trigger.style.display = ''; trigger.setAttribute('aria-expanded','false'); }

    trigger.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "Contact Widget",
  "tag": "aside",
  "class": "nexus-workbench-wrapper",
  "settings": [
    { "type": "checkbox", "id": "enable_workbench", "label": "Enable Contact Widget", "default": true },
    { "type": "text", "id": "wb_subtitle", "label": "Subtitle", "default": "We usually reply within a few hours" },
    { "type": "text", "id": "contact_email", "label": "Contact Email", "default": "hello@example.com" },
    { "type": "text", "id": "contact_phone", "label": "Contact Phone", "default": "+44 7XXX XXXXXX" },
    { "type": "text", "id": "response_note", "label": "Response Note", "default": "We typically reply within 24 hours" }
  ],
  "templates": ["index", "product", "collection", "page"]
}
{% endschema %}
