{%- comment -%}
  NEXUS-3D  ·  MAIN MATERIALS — "The Lab" page section
  Deep-dive material comparison with spec tables
{%- endcomment -%}

<section class="nexus-materials-page nexus-section" data-section-id="{{ section.id }}">
  <div class="nexus-container">

    <div class="nexus-materials-page__header" data-nexus-animate>
      <span class="nexus-materials-page__badge">[THE LAB]</span>
      <h1 class="nexus-materials-page__title">{{ section.settings.heading }}</h1>
      <p class="nexus-materials-page__subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="nexus-materials-page__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'material' -%}
          <div class="nexus-materials-page__card" data-nexus-animate {{ block.shopify_attributes }}>
            <div class="nexus-materials-page__card-head" style="border-left: 4px solid {{ block.settings.accent_color }};">
              <div class="nexus-materials-page__card-dot" style="background: {{ block.settings.accent_color }};"></div>
              <div>
                <h3 class="nexus-materials-page__card-name">{{ block.settings.name }}</h3>
                <span class="nexus-materials-page__card-type">{{ block.settings.type }}</span>
              </div>
            </div>
            <p class="nexus-materials-page__card-desc">{{ block.settings.description }}</p>

            <div class="nexus-materials-page__specs">
              {%- if block.settings.strength != blank -%}
                <div class="nexus-materials-page__spec-row">
                  <span class="nexus-materials-page__spec-label">Strength</span>
                  <div class="nexus-materials-page__spec-bar"><div style="width:{{ block.settings.strength }}%; background:{{ block.settings.accent_color }};"></div></div>
                  <span class="nexus-materials-page__spec-val">{{ block.settings.strength }}%</span>
                </div>
              {%- endif -%}
              {%- if block.settings.flexibility != blank -%}
                <div class="nexus-materials-page__spec-row">
                  <span class="nexus-materials-page__spec-label">Flexibility</span>
                  <div class="nexus-materials-page__spec-bar"><div style="width:{{ block.settings.flexibility }}%; background:{{ block.settings.accent_color }};"></div></div>
                  <span class="nexus-materials-page__spec-val">{{ block.settings.flexibility }}%</span>
                </div>
              {%- endif -%}
              {%- if block.settings.heat_resistance != blank -%}
                <div class="nexus-materials-page__spec-row">
                  <span class="nexus-materials-page__spec-label">Heat Res.</span>
                  <div class="nexus-materials-page__spec-bar"><div style="width:{{ block.settings.heat_resistance }}%; background:{{ block.settings.accent_color }};"></div></div>
                  <span class="nexus-materials-page__spec-val">{{ block.settings.heat_resistance }}%</span>
                </div>
              {%- endif -%}
              {%- if block.settings.detail != blank -%}
                <div class="nexus-materials-page__spec-row">
                  <span class="nexus-materials-page__spec-label">Detail</span>
                  <div class="nexus-materials-page__spec-bar"><div style="width:{{ block.settings.detail }}%; background:{{ block.settings.accent_color }};"></div></div>
                  <span class="nexus-materials-page__spec-val">{{ block.settings.detail }}%</span>
                </div>
              {%- endif -%}
            </div>

            <div class="nexus-materials-page__card-meta">
              {%- if block.settings.layer_min != blank -%}
                <span class="nexus-materials-page__meta-chip">Layer: {{ block.settings.layer_min }}</span>
              {%- endif -%}
              {%- if block.settings.temp != blank -%}
                <span class="nexus-materials-page__meta-chip">Temp: {{ block.settings.temp }}</span>
              {%- endif -%}
              {%- if block.settings.price_tier != blank -%}
                <span class="nexus-materials-page__meta-chip">{{ block.settings.price_tier }}</span>
              {%- endif -%}
            </div>

            {%- if block.settings.best_for != blank -%}
              <div class="nexus-materials-page__best-for">
                <span class="nexus-materials-page__bf-label">Best For</span>
                <span>{{ block.settings.best_for }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .nexus-materials-page__header { text-align: center; margin-bottom: 48px; }
  .nexus-materials-page__badge {
    display: inline-block;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--nx-primary); margin-bottom: 12px;
  }
  .nexus-materials-page__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 12px;
  }
  .nexus-materials-page__subtitle {
    font-size: 1.05rem; color: var(--nx-body); opacity: .65;
    max-width: 560px; margin: 0 auto; line-height: 1.65;
  }

  .nexus-materials-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .nexus-materials-page__card {
    background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 28px;
    box-shadow: var(--nx-shadow-sm);
    transition: transform .3s, box-shadow .3s;
  }
  .nexus-materials-page__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--nx-shadow-md);
  }

  .nexus-materials-page__card-head {
    display: flex; align-items: center; gap: 12px;
    padding-left: 16px; margin-bottom: 16px;
  }
  .nexus-materials-page__card-dot {
    width: 12px; height: 12px;
    border-radius: 50%; flex-shrink: 0;
  }
  .nexus-materials-page__card-name {
    font-family: var(--nx-font-heading); font-weight: 800;
    font-size: 1.3rem; color: var(--nx-dark); margin: 0;
  }
  .nexus-materials-page__card-type {
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; color: var(--nx-body); opacity: .5;
  }

  .nexus-materials-page__card-desc {
    font-size: .88rem; color: var(--nx-body);
    line-height: 1.65; margin: 0 0 20px;
  }

  .nexus-materials-page__specs { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .nexus-materials-page__spec-row { display: flex; align-items: center; gap: 10px; }
  .nexus-materials-page__spec-label {
    width: 80px; flex-shrink: 0;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .04em;
    color: var(--nx-body); opacity: .6;
  }
  .nexus-materials-page__spec-bar {
    flex: 1; height: 6px;
    background: var(--nx-outline);
    border-radius: 3px; overflow: hidden;
  }
  .nexus-materials-page__spec-bar > div {
    height: 100%; border-radius: 3px;
    transition: width .6s ease;
  }
  .nexus-materials-page__spec-val {
    width: 36px; text-align: right;
    font-family: var(--nx-font-mono); font-size: 11px;
    font-weight: 700; color: var(--nx-dark);
  }

  .nexus-materials-page__card-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
  .nexus-materials-page__meta-chip {
    font-family: var(--nx-font-mono); font-size: 10px;
    padding: 4px 12px;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    color: var(--nx-body);
  }

  .nexus-materials-page__best-for {
    padding-top: 14px;
    border-top: 1px solid var(--nx-outline);
    font-size: .85rem; color: var(--nx-body);
    line-height: 1.5;
  }
  .nexus-materials-page__bf-label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-primary); font-weight: 700;
    margin-bottom: 4px;
  }

  @media (max-width: 640px) {
    .nexus-materials-page__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Materials Lab",
  "tag": "section",
  "class": "nexus-section-materials-page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Material Lab" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Deep-dive into every material we offer. Compare properties, discover what's best for your project." }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "PLA" },
        { "type": "text", "id": "type", "label": "Type", "default": "FDM Filament" },
        { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#5C7285" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "The go-to material for prototyping. Biodegradable, easy to print, and available in many colors." },
        { "type": "range", "id": "strength", "label": "Strength", "min": 0, "max": 100, "step": 5, "default": 60 },
        { "type": "range", "id": "flexibility", "label": "Flexibility", "min": 0, "max": 100, "step": 5, "default": 40 },
        { "type": "range", "id": "heat_resistance", "label": "Heat Resistance", "min": 0, "max": 100, "step": 5, "default": 30 },
        { "type": "range", "id": "detail", "label": "Detail Resolution", "min": 0, "max": 100, "step": 5, "default": 70 },
        { "type": "text", "id": "layer_min", "label": "Min Layer Height", "default": "0.1mm" },
        { "type": "text", "id": "temp", "label": "Print Temp", "default": "200°C" },
        { "type": "text", "id": "price_tier", "label": "Price Tier", "default": "$$" },
        { "type": "text", "id": "best_for", "label": "Best For", "default": "Prototypes, display models, low-stress parts" }
      ]
    }
  ],
  "presets": [{
    "name": "Materials Lab",
    "blocks": [
      { "type": "material", "settings": { "name": "PLA", "type": "FDM Filament", "accent_color": "#5C7285", "strength": 60, "flexibility": 40, "heat_resistance": 30, "detail": 70, "layer_min": "0.1mm", "temp": "200°C", "price_tier": "$$", "best_for": "Prototypes, display models, low-stress parts" }},
      { "type": "material", "settings": { "name": "Resin (SLA)", "type": "Photopolymer", "accent_color": "#8B6F47", "strength": 45, "flexibility": 20, "heat_resistance": 35, "detail": 95, "layer_min": "0.025mm", "temp": "N/A", "price_tier": "$$$", "best_for": "Miniatures, jewelry, dental, high-detail prototypes" }},
      { "type": "material", "settings": { "name": "Nylon (PA12)", "type": "FDM / SLS", "accent_color": "#2D6A4F", "strength": 90, "flexibility": 75, "heat_resistance": 80, "detail": 55, "layer_min": "0.1mm", "temp": "250°C", "price_tier": "$$$$", "best_for": "Functional parts, hinges, snap-fits, gears" }},
      { "type": "material", "settings": { "name": "PETG", "type": "FDM Filament", "accent_color": "#3B82F6", "strength": 75, "flexibility": 55, "heat_resistance": 65, "detail": 60, "layer_min": "0.1mm", "temp": "230°C", "price_tier": "$$", "best_for": "Outdoor parts, food-safe containers, mechanical parts" }}
    ]
  }]
}
{% endschema %}
