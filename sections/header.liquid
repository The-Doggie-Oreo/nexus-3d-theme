{%- comment -%}
  NEXUS-3D  ·  HEADER — Material 3 Pill Navigation
{%- endcomment -%}

<header class="nexus-header" id="NexusHeader">
  <div class="nexus-header__inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="nexus-header__logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          loading="eager"
        >
      {%- else -%}
        <span class="nexus-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} M3 Pill Navigation — Centered {%- endcomment -%}
    <nav class="nexus-header__nav" aria-label="Main navigation">
      <div class="nexus-header__pill-track">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="nexus-header__pill {% if link.active %}is-active{% endif %}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </div>
    </nav>

    {%- comment -%} Right actions {%- endcomment -%}
    <div class="nexus-header__actions">
      <a href="{{ routes.search_url }}" class="nexus-header__action" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a href="{{ routes.account_url }}" class="nexus-header__action" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
    </div>

    {%- comment -%} Mobile toggle {%- endcomment -%}
    <button class="nexus-header__mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  {%- comment -%} Mobile drawer {%- endcomment -%}
  <div class="nexus-header__mobile-nav" id="MobileNav" aria-hidden="true">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" class="nexus-header__mobile-link {% if link.active %}is-active{% endif %}">
        {{ link.title }}
      </a>
    {%- endfor -%}
  </div>
</header>

<style>
  /* ================================================
     HEADER — M3 Pill Navigation
     ================================================ */
  .nexus-header {
    position: sticky;
    top: 0;
    z-index: 900;
    background: var(--nexus-glass);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--nexus-glass-border);
  }
  .nexus-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
    height: 68px;
    gap: 24px;
  }

  /* Logo */
  .nexus-header__logo { text-decoration: none; }
  .nexus-header__logo-text {
    font-family: var(--nexus-font-heading);
    font-weight: var(--nexus-heading-weight, 900);
    font-size: 1.25rem;
    color: #fff;
    letter-spacing: -.02em;
  }

  /* ── M3 Pill Navigation Track ── */
  .nexus-header__nav {
    display: flex;
    justify-content: center;
  }
  .nexus-header__pill-track {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px;
    background: var(--m3-surface-container);
    border-radius: var(--m3-radius-full);
    border: 1px solid var(--m3-outline-variant);
  }
  .nexus-header__pill {
    font-family: var(--nexus-font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: .01em;
    padding: 8px 20px;
    border-radius: var(--m3-radius-full);
    color: var(--m3-on-surface-variant);
    text-decoration: none;
    transition: all .25s cubic-bezier(.2, 0, 0, 1);
    white-space: nowrap;
  }
  .nexus-header__pill:hover {
    background: rgba(208, 188, 255, .08);
    color: var(--nexus-accent);
  }
  .nexus-header__pill.is-active {
    background: var(--m3-primary, #D0BCFF);
    color: var(--m3-on-primary, #381E72);
    font-weight: 600;
    box-shadow: var(--m3-elevation-1);
  }

  /* Actions */
  .nexus-header__actions {
    display: flex;
    gap: 4px;
  }
  .nexus-header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--m3-radius-full);
    color: var(--m3-on-surface-variant);
    text-decoration: none;
    transition: all .2s;
  }
  .nexus-header__action:hover {
    background: rgba(208, 188, 255, .08);
    color: var(--nexus-accent);
  }

  /* Mobile toggle */
  .nexus-header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--nexus-text);
    cursor: pointer;
    width: 40px;
    height: 40px;
    border-radius: var(--m3-radius-full);
    align-items: center;
    justify-content: center;
    transition: background .2s;
  }
  .nexus-header__mobile-toggle:hover {
    background: rgba(208, 188, 255, .08);
  }

  /* Mobile drawer */
  .nexus-header__mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 16px 16px;
    gap: 4px;
    background: var(--m3-surface-container-high);
    border-top: 1px solid var(--m3-outline-variant);
  }
  .nexus-header__mobile-nav[aria-hidden="false"] {
    display: flex;
  }
  .nexus-header__mobile-link {
    padding: 12px 20px;
    border-radius: var(--m3-radius-full);
    font-family: var(--nexus-font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--m3-on-surface-variant);
    text-decoration: none;
    transition: all .2s;
  }
  .nexus-header__mobile-link:hover {
    background: rgba(208, 188, 255, .08);
  }
  .nexus-header__mobile-link.is-active {
    background: var(--m3-primary, #D0BCFF);
    color: var(--m3-on-primary, #381E72);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .nexus-header__nav { display: none; }
    .nexus-header__mobile-toggle { display: flex; }
    .nexus-header__inner {
      grid-template-columns: auto 1fr auto;
      padding: 0 16px;
      height: 60px;
    }
    .nexus-header__actions { gap: 2px; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "class": "nexus-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
