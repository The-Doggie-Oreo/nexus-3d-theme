{%- comment -%}
  NEXUS-3D  ·  HEADER — Linen & Steel M3 Pill Navigation
  Centered logo · Pill nav · Glassmorphism on scroll
{%- endcomment -%}

<header class="nexus-header" id="NexusHeader">
  <div class="nexus-header__inner">

    {%- comment -%} Logo — Centered {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="nexus-header__logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          loading="eager"
        >
      {%- else -%}
        <span class="nexus-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Pill Navigation Bar {%- endcomment -%}
    <nav class="nexus-header__nav" aria-label="Main navigation">
      <div class="nexus-header__pill-track">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="nexus-header__pill {% if link.active %}is-active{% endif %}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </div>
    </nav>

    {%- comment -%} Right actions {%- endcomment -%}
    <div class="nexus-header__actions">
      <a href="{{ routes.search_url }}" class="nexus-header__action" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="nexus-header__action nexus-header__cart" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="nexus-header__cart-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Mobile toggle {%- endcomment -%}
    <button class="nexus-header__mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  {%- comment -%} Mobile drawer {%- endcomment -%}
  <div class="nexus-header__mobile-nav" id="MobileNav" aria-hidden="true">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" class="nexus-header__mobile-link {% if link.active %}is-active{% endif %}">
        {{ link.title }}
      </a>
    {%- endfor -%}
  </div>
</header>

<style>
  .nexus-header {
    position: sticky;
    top: 0;
    z-index: 900;
    background: var(--nx-bg);
    border-bottom: 1px solid var(--nx-outline);
    transition: background .3s, backdrop-filter .3s, box-shadow .3s;
  }
  .nexus-header.is-scrolled {
    background: var(--nx-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--nx-glass-border);
    box-shadow: var(--nx-shadow-sm);
  }
  .nexus-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
    height: 72px;
    gap: 24px;
  }

  /* Logo — First column, left-aligned */
  .nexus-header__logo { text-decoration: none; justify-self: start; }
  .nexus-header__logo-text {
    font-family: var(--nx-font-heading);
    font-weight: var(--nx-heading-weight, 800);
    font-size: 1.3rem;
    color: var(--nx-dark);
    letter-spacing: -.03em;
  }

  /* Pill Navigation — Centered */
  .nexus-header__nav {
    display: flex;
    justify-content: center;
  }
  .nexus-header__pill-track {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px;
    background: var(--nx-surface);
    border-radius: var(--nx-radius-pill);
    border: 1px solid var(--nx-outline);
  }
  .nexus-header__pill {
    font-family: var(--nx-font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: .01em;
    padding: 8px 20px;
    border-radius: var(--nx-radius-pill);
    color: var(--nx-body);
    text-decoration: none;
    transition: all .25s cubic-bezier(.2, 0, 0, 1);
    white-space: nowrap;
  }
  .nexus-header__pill:hover {
    background: var(--nx-primary-06);
    color: var(--nx-primary);
  }
  .nexus-header__pill.is-active {
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    font-weight: 700;
    box-shadow: var(--nx-shadow-sm);
  }

  /* Actions — Right */
  .nexus-header__actions {
    display: flex;
    gap: 4px;
    justify-self: end;
  }
  .nexus-header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--nx-radius-pill);
    color: var(--nx-body);
    text-decoration: none;
    transition: all .2s;
    position: relative;
  }
  .nexus-header__action:hover {
    background: var(--nx-primary-06);
    color: var(--nx-primary);
  }
  .nexus-header__cart-badge {
    position: absolute;
    top: 2px; right: 2px;
    min-width: 16px; height: 16px;
    border-radius: var(--nx-radius-pill);
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    font-family: var(--nx-font-mono);
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-weight: 700;
  }

  /* Mobile toggle */
  .nexus-header__mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--nx-dark);
    cursor: pointer;
    width: 40px; height: 40px;
    border-radius: var(--nx-radius-pill);
    align-items: center;
    justify-content: center;
    transition: background .2s;
  }
  .nexus-header__mobile-toggle:hover {
    background: var(--nx-primary-06);
  }

  /* Mobile drawer */
  .nexus-header__mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 16px 16px;
    gap: 4px;
    background: var(--nx-bg);
    border-top: 1px solid var(--nx-outline);
  }
  .nexus-header__mobile-nav[aria-hidden="false"] {
    display: flex;
  }
  .nexus-header__mobile-link {
    padding: 12px 20px;
    border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--nx-body);
    text-decoration: none;
    transition: all .2s;
  }
  .nexus-header__mobile-link:hover {
    background: var(--nx-primary-06);
    color: var(--nx-primary);
  }
  .nexus-header__mobile-link.is-active {
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .nexus-header__nav { display: none; }
    .nexus-header__mobile-toggle { display: flex; }
    .nexus-header__inner {
      grid-template-columns: auto 1fr auto;
      padding: 0 16px;
      height: 60px;
    }
    .nexus-header__actions { gap: 2px; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "class": "nexus-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
