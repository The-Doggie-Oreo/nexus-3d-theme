{%- comment -%}
  ============================================================
  NEXUS-3D  ·  SECTION: THE "AURA" HERO
  Full-width hero with large product image, gradient mask,
  bold Outfit headline, and massive floating search bar.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign hero_image   = section.settings.hero_image
  assign heading      = section.settings.heading
  assign subheading   = section.settings.subheading
  assign cta_label    = section.settings.cta_label
  assign cta_link     = section.settings.cta_link
  assign cta2_label   = section.settings.cta2_label
  assign cta2_link    = section.settings.cta2_link
  assign show_search  = section.settings.show_search
-%}

<section id="HeroAura-{{ section.id }}" class="nexus-aura" data-section-type="hero-aura">

  {%- comment -%} Background image with gradient mask {%- endcomment -%}
  <div class="nexus-aura__media">
    {%- if hero_image != blank -%}
      <img
        class="nexus-aura__image"
        src="{{ hero_image | image_url: width: 1920 }}"
        srcset="{{ hero_image | image_url: width: 960 }} 960w,
                {{ hero_image | image_url: width: 1440 }} 1440w,
                {{ hero_image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ hero_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ hero_image.width }}"
        height="{{ hero_image.height }}"
      >
    {%- else -%}
      <div class="nexus-aura__placeholder"></div>
    {%- endif -%}
    <div class="nexus-aura__gradient"></div>
  </div>

  {%- comment -%} Content overlay {%- endcomment -%}
  <div class="nexus-aura__content">
    <div class="nexus-aura__inner">

      {%- comment -%} Badge {%- endcomment -%}
      <div class="nexus-aura__badge">
        <span class="nexus-aura__badge-dot"></span>
        <span>{{ section.settings.badge_text | default: 'Now Accepting Orders' }}</span>
      </div>

      {%- comment -%} Headline {%- endcomment -%}
      {%- if heading != blank -%}
        <h1 class="nexus-aura__heading">{{ heading }}</h1>
      {%- endif -%}

      {%- comment -%} Subheading {%- endcomment -%}
      {%- if subheading != blank -%}
        <p class="nexus-aura__subheading">{{ subheading }}</p>
      {%- endif -%}

      {%- comment -%} Search bar {%- endcomment -%}
      {%- if show_search -%}
        <div class="nexus-aura__search">
          <form action="{{ routes.search_url }}" method="get" role="search" class="nexus-aura__search-form">
            <svg class="nexus-aura__search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input
              type="search"
              name="q"
              class="nexus-aura__search-input"
              placeholder="Search prints, materials, prototypes..."
              autocomplete="off"
            >
            <button type="submit" class="nexus-btn nexus-btn--primary nexus-btn--sm nexus-aura__search-btn">Search</button>
          </form>
        </div>
      {%- endif -%}

      {%- comment -%} CTAs {%- endcomment -%}
      <div class="nexus-aura__ctas">
        {%- if cta_label != blank -%}
          <a href="{{ cta_link }}" class="nexus-btn nexus-btn--primary nexus-btn--lg">{{ cta_label }}</a>
        {%- endif -%}
        {%- if cta2_label != blank -%}
          <a href="{{ cta2_link }}" class="nexus-btn nexus-btn--outline nexus-btn--lg">{{ cta2_label }}</a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  .nexus-aura {
    position: relative;
    min-height: 90vh;
    min-height: 90dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--nx-bg);
  }

  /* Background image */
  .nexus-aura__media {
    position: absolute;
    inset: 0;
  }
  .nexus-aura__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .35;
  }
  .nexus-aura__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--nx-surface) 0%, var(--nx-bg) 100%);
  }
  .nexus-aura__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(253,252,251,0.3) 0%,
      rgba(253,252,251,0.75) 40%,
      rgba(253,252,251,0.95) 70%,
      var(--nx-bg) 100%
    );
  }

  /* Content */
  .nexus-aura__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 80px 24px 60px;
  }
  .nexus-aura__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* Badge */
  .nexus-aura__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    background: var(--nx-bg);
    font-family: var(--nx-font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--nx-primary);
    letter-spacing: .03em;
    text-transform: uppercase;
    margin-bottom: 32px;
    box-shadow: var(--nx-shadow-sm);
  }
  .nexus-aura__badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    animation: nexus-pulse 2s ease-in-out infinite;
  }

  /* Heading */
  .nexus-aura__heading {
    font-family: var(--nx-font-heading);
    font-weight: var(--nx-heading-weight, 800);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    color: var(--nx-dark);
    margin: 0 0 20px;
    letter-spacing: -.04em;
    text-transform: uppercase;
  }

  .nexus-aura__subheading {
    font-family: var(--nx-font-body);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--nx-body);
    line-height: 1.65;
    margin: 0 0 40px;
    max-width: 560px;
  }

  /* Floating Search Bar */
  .nexus-aura__search {
    width: 100%;
    max-width: 640px;
    margin-bottom: 32px;
  }
  .nexus-aura__search-form {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--nx-bg);
    border: 1.5px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    padding: 6px 6px 6px 20px;
    box-shadow: var(--nx-shadow-lg);
    transition: border-color .2s, box-shadow .2s;
  }
  .nexus-aura__search-form:focus-within {
    border-color: var(--nx-primary);
    box-shadow: var(--nx-shadow-xl), 0 0 0 3px var(--nx-primary-10);
  }
  .nexus-aura__search-icon {
    color: var(--nx-body);
    opacity: .4;
    flex-shrink: 0;
  }
  .nexus-aura__search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--nx-font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--nx-dark);
    padding: 12px 16px;
    outline: none;
  }
  .nexus-aura__search-input::placeholder {
    color: var(--nx-body);
    opacity: .45;
  }
  .nexus-aura__search-btn {
    flex-shrink: 0;
    padding: 12px 24px;
  }

  /* CTAs */
  .nexus-aura__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  @keyframes nexus-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: .5; transform: scale(1.5); }
  }

  @media (max-width: 768px) {
    .nexus-aura {
      min-height: 80vh;
    }
    .nexus-aura__content {
      padding: 60px 16px 40px;
    }
    .nexus-aura__heading {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }
</style>

{% schema %}
{
  "name": "Aura Hero",
  "tag": "section",
  "class": "nexus-section-hero",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Now Accepting Orders"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PRECISION PRINTS. DELIVERED."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From concept file to finished prototype — industrial-grade 3D printing for creators, engineers, and dreamers."
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary CTA Label",
      "default": "Upload STL"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA Link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary CTA Label",
      "default": "Browse Catalog"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Secondary CTA Link"
    }
  ],
  "presets": [
    {
      "name": "Aura Hero"
    }
  ]
}
{% endschema %}
