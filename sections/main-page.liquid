{%- comment -%} NEXUS-3D · MAIN PAGE {%- endcomment -%}

<section class="nexus-page" style="padding: 60px 32px 80px; max-width: 800px; margin: 0 auto;">
  <h1 style="font-family:var(--nexus-font-heading); font-weight:800; font-size:clamp(1.5rem,3vw,2.5rem); color:#fff; margin:0 0 24px;">{{ page.title }}</h1>
  <div style="font-size:.95rem; color:var(--nexus-text); opacity:.8; line-height:1.8;">
    {{ page.content }}
  </div>
</section>

{% schema %}
{
  "name": "Main Page",
  "tag": "section",
  "class": "nexus-section-page",
  "settings": [],
  "templates": ["page"]
}
{% endschema %}
