{%- comment -%} NEXUS-3D · MAIN PAGE — Linen & Steel {%- endcomment -%}

<section class="nexus-page nexus-section--compact">
  <div class="nexus-container" style="max-width: 800px;">
    <h1 style="font-family:var(--nx-font-heading); font-weight:800; font-size:clamp(1.5rem,3vw,2.5rem); color:var(--nx-dark); margin:0 0 24px;">{{ page.title }}</h1>
    <div class="nexus-page__content" style="font-size:.95rem; color:var(--nx-body); line-height:1.8;">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Page",
  "tag": "section",
  "class": "nexus-section-page",
  "settings": [],
  "templates": ["page"]
}
{% endschema %}
