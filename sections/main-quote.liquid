{%- comment -%}
  NEXUS-3D  ·  MAIN QUOTE — "Request a Quote" page
  Uses Shopify's built-in contact form (no fake uploads)
  Messages go straight to the store owner's email.
{%- endcomment -%}

<section class="nexus-quote nexus-section" data-section-id="{{ section.id }}">
  <div class="nexus-container" style="max-width: 800px;">

    <div class="nexus-quote__header" data-nexus-animate>
      <span class="nexus-quote__badge">[GET A QUOTE]</span>
      <h1 class="nexus-quote__title">{{ section.settings.heading }}</h1>
      <p class="nexus-quote__subtitle">{{ section.settings.subheading }}</p>
    </div>

    {%- comment -%} Show success/error after submission {%- endcomment -%}
    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div class="nexus-quote__success" data-nexus-animate>
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h3 style="font-family:var(--nx-font-heading); font-weight:800; color:var(--nx-dark); margin:12px 0 4px;">Message Sent!</h3>
          <p style="color:var(--nx-body); font-size:.9rem;">Thanks for reaching out. We'll get back to you within 24 hours with a detailed quote.</p>
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="nexus-quote__error">
          <p style="color:#c0392b; font-family:var(--nx-font-mono); font-size:12px;">{{ form.errors | default_errors }}</p>
        </div>
      {%- endif -%}

      <div class="nexus-quote__form" data-nexus-animate>
        <div class="nexus-quote__row">
          <div class="nexus-quote__field">
            <label class="nexus-quote__label" for="QuoteName">Full Name *</label>
            <input type="text" id="QuoteName" name="contact[name]" required class="nexus-quote__input" placeholder="James Wright" value="{{ form.name }}">
          </div>
          <div class="nexus-quote__field">
            <label class="nexus-quote__label" for="QuoteEmail">Email Address *</label>
            <input type="email" id="QuoteEmail" name="contact[email]" required class="nexus-quote__input" placeholder="james@example.com" value="{{ form.email }}">
          </div>
        </div>

        <div class="nexus-quote__row">
          <div class="nexus-quote__field">
            <label class="nexus-quote__label" for="QuotePhone">Phone (optional)</label>
            <input type="tel" id="QuotePhone" name="contact[phone]" class="nexus-quote__input" placeholder="+44 7XXX XXXXXX">
          </div>
          <div class="nexus-quote__field">
            <label class="nexus-quote__label" for="QuoteMaterial">Preferred Material</label>
            <select id="QuoteMaterial" name="contact[material]" class="nexus-quote__input nexus-quote__select">
              <option value="">Select material...</option>
              <option value="PLA">PLA — Standard</option>
              <option value="Resin">Resin — High Detail</option>
              <option value="Nylon">Nylon — Durable</option>
              <option value="PETG">PETG — Flexible</option>
              <option value="Unsure">Not sure — advise me</option>
            </select>
          </div>
        </div>

        <div class="nexus-quote__row">
          <div class="nexus-quote__field">
            <label class="nexus-quote__label" for="QuoteQuantity">Quantity</label>
            <input type="number" id="QuoteQuantity" name="contact[quantity]" min="1" value="1" class="nexus-quote__input" style="max-width: 120px;">
          </div>
          <div class="nexus-quote__field">
            <label class="nexus-quote__label" for="QuoteTimeline">Timeline</label>
            <select id="QuoteTimeline" name="contact[timeline]" class="nexus-quote__input nexus-quote__select">
              <option value="No rush">No rush</option>
              <option value="1-2 weeks">1–2 weeks</option>
              <option value="This week">This week</option>
              <option value="Urgent (24-48h)">Urgent (24–48h)</option>
            </select>
          </div>
        </div>

        {%- comment -%} File sharing guidance (realistic — no fake upload) {%- endcomment -%}
        <div class="nexus-quote__file-note">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          <div>
            <strong style="font-family:var(--nx-font-heading); font-weight:700; color:var(--nx-dark); font-size:.85rem;">Have a 3D file?</strong>
            <p style="font-size:.82rem; color:var(--nx-body); margin:4px 0 0; line-height:1.5;">
              Mention it below and we'll send you a secure upload link via email. We accept STL, OBJ, STEP and 3MF files.
            </p>
          </div>
        </div>

        <div class="nexus-quote__field">
          <label class="nexus-quote__label" for="QuoteNotes">Project Details *</label>
          <textarea id="QuoteNotes" name="contact[body]" rows="5" required class="nexus-quote__input nexus-quote__textarea" placeholder="Tell us about your project — dimensions, finish, deadline, file details...">{{ form.body }}</textarea>
        </div>

        <button type="submit" class="nexus-btn nexus-btn--primary nexus-btn--lg nexus-btn--full" style="margin-top: 8px;">
          Send Quote Request
        </button>
        <p style="font-family:var(--nx-font-mono); font-size:11px; text-align:center; color:var(--nx-body); opacity:.4; margin-top:12px;">
          We'll reply within 24 hours. Your email goes straight to our team.
        </p>
      </div>
    {%- endform -%}

  </div>
</section>

<style>
  .nexus-quote__header { text-align: center; margin-bottom: 48px; }
  .nexus-quote__badge {
    display: inline-block;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--nx-primary); margin-bottom: 12px;
  }
  .nexus-quote__title { font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 12px; }
  .nexus-quote__subtitle {
    font-size: 1.05rem; color: var(--nx-body); opacity: .65;
    max-width: 480px; margin: 0 auto; line-height: 1.65;
  }

  .nexus-quote__success {
    text-align: center;
    padding: 40px;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    margin-bottom: 24px;
  }
  .nexus-quote__error {
    padding: 16px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: var(--nx-radius-lg);
    margin-bottom: 16px;
  }

  .nexus-quote__form {
    background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 40px;
    box-shadow: var(--nx-shadow-md);
  }

  .nexus-quote__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .nexus-quote__field { margin-bottom: 18px; }
  .nexus-quote__label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .55;
    margin-bottom: 6px;
  }
  .nexus-quote__input {
    width: 100%; padding: 12px 16px;
    background: var(--nx-surface); color: var(--nx-dark);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-body); font-size: .9rem;
    transition: border-color .2s, box-shadow .2s;
  }
  .nexus-quote__input:focus {
    outline: none; border-color: var(--nx-primary);
    box-shadow: 0 0 0 3px var(--nx-primary-10);
  }
  .nexus-quote__select { appearance: none; cursor: pointer; }
  .nexus-quote__textarea {
    border-radius: var(--nx-radius-lg);
    resize: vertical; min-height: 100px;
  }

  .nexus-quote__file-note {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 16px 20px;
    background: var(--nx-primary-04);
    border: 1px solid var(--nx-primary-10);
    border-radius: var(--nx-radius-lg);
    margin-bottom: 18px;
  }
  .nexus-quote__file-note svg { flex-shrink: 0; margin-top: 2px; }

  @media (max-width: 640px) {
    .nexus-quote__row { grid-template-columns: 1fr; }
    .nexus-quote__form { padding: 24px; }
  }
</style>

{% schema %}
{
  "name": "Quote Form",
  "tag": "section",
  "class": "nexus-section-quote",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a Quote" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Tell us about your project and we'll get back to you with a detailed quote within 24 hours." }
  ],
  "presets": [{ "name": "Quote Form" }]
}
{% endschema %}
