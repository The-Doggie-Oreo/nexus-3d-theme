{%- comment -%}
  NEXUS-3D  ·  MAIN QUOTE — "Request a Quote" page section
  Contact form with file upload zone
{%- endcomment -%}

<section class="nexus-quote nexus-section" data-section-id="{{ section.id }}">
  <div class="nexus-container" style="max-width: 800px;">

    <div class="nexus-quote__header" data-nexus-animate>
      <span class="nexus-quote__badge">[GET A QUOTE]</span>
      <h1 class="nexus-quote__title">{{ section.settings.heading }}</h1>
      <p class="nexus-quote__subtitle">{{ section.settings.subheading }}</p>
    </div>

    <form class="nexus-quote__form" data-nexus-animate>
      <div class="nexus-quote__row">
        <div class="nexus-quote__field">
          <label class="nexus-quote__label" for="QuoteName">Full Name</label>
          <input type="text" id="QuoteName" name="name" required class="nexus-quote__input" placeholder="James Wright">
        </div>
        <div class="nexus-quote__field">
          <label class="nexus-quote__label" for="QuoteEmail">Email Address</label>
          <input type="email" id="QuoteEmail" name="email" required class="nexus-quote__input" placeholder="james@example.com">
        </div>
      </div>

      <div class="nexus-quote__row">
        <div class="nexus-quote__field">
          <label class="nexus-quote__label" for="QuotePhone">Phone (optional)</label>
          <input type="tel" id="QuotePhone" name="phone" class="nexus-quote__input" placeholder="+44 7XXX XXXXXX">
        </div>
        <div class="nexus-quote__field">
          <label class="nexus-quote__label" for="QuoteMaterial">Preferred Material</label>
          <select id="QuoteMaterial" name="material" class="nexus-quote__input nexus-quote__select">
            <option value="">Select material...</option>
            <option value="PLA">PLA — Standard</option>
            <option value="Resin">Resin — High Detail</option>
            <option value="Nylon">Nylon — Durable</option>
            <option value="PETG">PETG — Flexible</option>
            <option value="Unsure">Not sure — advise me</option>
          </select>
        </div>
      </div>

      <div class="nexus-quote__field">
        <label class="nexus-quote__label" for="QuoteQuantity">Quantity</label>
        <input type="number" id="QuoteQuantity" name="quantity" min="1" value="1" class="nexus-quote__input" style="max-width: 120px;">
      </div>

      {%- comment -%} File Upload Zone {%- endcomment -%}
      <div class="nexus-quote__field">
        <label class="nexus-quote__label">Upload 3D File</label>
        <div class="nexus-quote__upload" id="QuoteDropzone">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <p style="font-family:var(--nx-font-heading); font-weight:700; color:var(--nx-dark); margin:10px 0 4px; font-size:.95rem;">Drop your file here</p>
          <p style="font-size:.82rem; color:var(--nx-body); opacity:.5;">STL · OBJ · STEP · 3MF — Max 50 MB</p>
          <input type="file" accept=".stl,.obj,.step,.stp,.3mf" style="display:none;" id="QuoteFileInput">
          <button type="button" class="nexus-btn nexus-btn--outline nexus-btn--sm" style="margin-top: 12px;" onclick="document.getElementById('QuoteFileInput').click()">Browse Files</button>
        </div>
      </div>

      <div class="nexus-quote__field">
        <label class="nexus-quote__label" for="QuoteNotes">Project Details</label>
        <textarea id="QuoteNotes" name="notes" rows="5" class="nexus-quote__input nexus-quote__textarea" placeholder="Tell us about your project — dimensions, finish, deadline, any special requirements..."></textarea>
      </div>

      <button type="submit" class="nexus-btn nexus-btn--primary nexus-btn--lg nexus-btn--full" style="margin-top: 8px;">
        Submit Quote Request
      </button>
      <p style="font-family:var(--nx-font-mono); font-size:11px; text-align:center; color:var(--nx-body); opacity:.4; margin-top:12px;">
        We'll reply within 24 hours with a detailed quote.
      </p>
    </form>

  </div>
</section>

<style>
  .nexus-quote__header { text-align: center; margin-bottom: 48px; }
  .nexus-quote__badge {
    display: inline-block;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--nx-primary); margin-bottom: 12px;
  }
  .nexus-quote__title { font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 12px; }
  .nexus-quote__subtitle {
    font-size: 1.05rem; color: var(--nx-body); opacity: .65;
    max-width: 480px; margin: 0 auto; line-height: 1.65;
  }

  .nexus-quote__form {
    background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 40px;
    box-shadow: var(--nx-shadow-md);
  }

  .nexus-quote__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .nexus-quote__field { margin-bottom: 18px; }
  .nexus-quote__label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .55;
    margin-bottom: 6px;
  }
  .nexus-quote__input {
    width: 100%; padding: 12px 16px;
    background: var(--nx-surface); color: var(--nx-dark);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-body); font-size: .9rem;
    transition: border-color .2s, box-shadow .2s;
  }
  .nexus-quote__input:focus {
    outline: none; border-color: var(--nx-primary);
    box-shadow: 0 0 0 3px var(--nx-primary-10);
  }
  .nexus-quote__select { appearance: none; cursor: pointer; }
  .nexus-quote__textarea {
    border-radius: var(--nx-radius-lg);
    resize: vertical; min-height: 100px;
  }

  .nexus-quote__upload {
    display: flex; flex-direction: column;
    align-items: center; padding: 36px;
    border: 2px dashed var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    text-align: center;
    transition: border-color .2s, background .2s;
    cursor: pointer;
  }
  .nexus-quote__upload:hover,
  .nexus-quote__upload.is-drag-over {
    border-color: var(--nx-primary);
    background: var(--nx-primary-04);
  }

  @media (max-width: 640px) {
    .nexus-quote__row { grid-template-columns: 1fr; }
    .nexus-quote__form { padding: 24px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var dropzone = document.getElementById('QuoteDropzone');
    if (!dropzone) return;
    ['dragenter','dragover'].forEach(function(e){ dropzone.addEventListener(e, function(ev){ ev.preventDefault(); dropzone.classList.add('is-drag-over'); }); });
    ['dragleave','drop'].forEach(function(e){ dropzone.addEventListener(e, function(){ dropzone.classList.remove('is-drag-over'); }); });
  });
</script>

{% schema %}
{
  "name": "Quote Form",
  "tag": "section",
  "class": "nexus-section-quote",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a Quote" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Upload your 3D file and tell us what you need. We'll get back to you with a detailed quote within 24 hours." }
  ],
  "presets": [{ "name": "Quote Form" }]
}
{% endschema %}
