{%- comment -%}
  ============================================================
  NEXUS-3D  ·  SECTION: THE MATERIAL LAB
  Interactive material selector with progress bars.
  Left: Material names (PLA, Resin, Nylon)
  Right: Dynamic bars for Strength, Flex, Heat Resistance
  ============================================================
{%- endcomment -%}

<section class="nexus-material-lab nexus-section" data-section-type="material-lab">
  <div class="nexus-material-lab__inner nexus-container">

    <div class="nexus-material-lab__header" data-nexus-animate>
      <h2 class="nexus-material-lab__title">{{ section.settings.heading | default: 'The Material Lab' }}</h2>
      <p class="nexus-material-lab__subtitle">{{ section.settings.subheading | default: 'Explore the properties of every filament and resin we stock.' }}</p>
    </div>

    <div class="nexus-material-lab__grid" data-nexus-animate>

      {%- comment -%} Left: Material list {%- endcomment -%}
      <div class="nexus-material-lab__list">
        {%- for block in section.blocks -%}
          <button
            class="nexus-material-lab__material {% if forloop.first %}is-active{% endif %}"
            data-material="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <span class="nexus-material-lab__mat-dot" style="background: {{ block.settings.color | default: '#5C7285' }}"></span>
            <span class="nexus-material-lab__mat-name">{{ block.settings.name }}</span>
            <span class="nexus-material-lab__mat-type">{{ block.settings.type }}</span>
            <svg class="nexus-material-lab__mat-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endfor -%}
      </div>

      {%- comment -%} Right: Properties panels {%- endcomment -%}
      <div class="nexus-material-lab__details">
        {%- for block in section.blocks -%}
          <div
            class="nexus-material-lab__panel {% if forloop.first %}is-active{% endif %}"
            data-material-panel="{{ block.id }}"
          >
            <h3 class="nexus-material-lab__panel-title">{{ block.settings.name }}</h3>
            <p class="nexus-material-lab__panel-desc">{{ block.settings.description }}</p>

            <div class="nexus-material-lab__bars">
              <div class="nexus-material-lab__bar-item">
                <div class="nexus-material-lab__bar-label">
                  <span>Strength</span>
                  <span class="nexus-material-lab__bar-val">{{ block.settings.strength }}%</span>
                </div>
                <div class="nexus-material-lab__bar-track">
                  <div class="nexus-material-lab__bar-fill" style="width: {{ block.settings.strength }}%; background: {{ block.settings.color | default: '#5C7285' }}"></div>
                </div>
              </div>

              <div class="nexus-material-lab__bar-item">
                <div class="nexus-material-lab__bar-label">
                  <span>Flexibility</span>
                  <span class="nexus-material-lab__bar-val">{{ block.settings.flex }}%</span>
                </div>
                <div class="nexus-material-lab__bar-track">
                  <div class="nexus-material-lab__bar-fill" style="width: {{ block.settings.flex }}%; background: {{ block.settings.color | default: '#5C7285' }}"></div>
                </div>
              </div>

              <div class="nexus-material-lab__bar-item">
                <div class="nexus-material-lab__bar-label">
                  <span>Heat Resistance</span>
                  <span class="nexus-material-lab__bar-val">{{ block.settings.heat }}%</span>
                </div>
                <div class="nexus-material-lab__bar-track">
                  <div class="nexus-material-lab__bar-fill" style="width: {{ block.settings.heat }}%; background: {{ block.settings.color | default: '#5C7285' }}"></div>
                </div>
              </div>

              <div class="nexus-material-lab__bar-item">
                <div class="nexus-material-lab__bar-label">
                  <span>Detail Resolution</span>
                  <span class="nexus-material-lab__bar-val">{{ block.settings.detail }}%</span>
                </div>
                <div class="nexus-material-lab__bar-track">
                  <div class="nexus-material-lab__bar-fill" style="width: {{ block.settings.detail }}%; background: {{ block.settings.color | default: '#5C7285' }}"></div>
                </div>
              </div>
            </div>

            <div class="nexus-material-lab__meta">
              <span class="nexus-material-lab__meta-chip">
                <strong>Layer Min:</strong> {{ block.settings.layer_min | default: '0.1mm' }}
              </span>
              <span class="nexus-material-lab__meta-chip">
                <strong>Temp:</strong> {{ block.settings.temp | default: '200°C' }}
              </span>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<style>
  .nexus-material-lab__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .nexus-material-lab__title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    margin: 0 0 12px;
  }
  .nexus-material-lab__subtitle {
    font-size: 1.05rem;
    color: var(--nx-body);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.65;
  }

  .nexus-material-lab__grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* Left: Material buttons */
  .nexus-material-lab__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .nexus-material-lab__material {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: var(--nx-bg);
    border: 1.5px solid var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    cursor: pointer;
    transition: all .25s cubic-bezier(.2, 0, 0, 1);
    text-align: left;
    font-family: var(--nx-font-body);
  }
  .nexus-material-lab__material:hover {
    border-color: var(--nx-primary);
    box-shadow: var(--nx-shadow-md);
  }
  .nexus-material-lab__material.is-active {
    background: var(--nx-primary);
    border-color: var(--nx-primary);
    box-shadow: var(--nx-shadow-md);
  }
  .nexus-material-lab__material.is-active .nexus-material-lab__mat-name,
  .nexus-material-lab__material.is-active .nexus-material-lab__mat-type,
  .nexus-material-lab__material.is-active .nexus-material-lab__mat-arrow {
    color: var(--nx-on-primary);
  }
  .nexus-material-lab__material.is-active .nexus-material-lab__mat-dot {
    background: var(--nx-on-primary) !important;
  }

  .nexus-material-lab__mat-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .nexus-material-lab__mat-name {
    font-weight: 700;
    font-size: .95rem;
    color: var(--nx-dark);
    flex: 1;
  }
  .nexus-material-lab__mat-type {
    font-family: var(--nx-font-mono);
    font-size: 11px;
    color: var(--nx-body);
    opacity: .6;
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .nexus-material-lab__mat-arrow {
    color: var(--nx-body);
    opacity: .3;
    transition: opacity .2s;
  }
  .nexus-material-lab__material:hover .nexus-material-lab__mat-arrow { opacity: .8; }

  /* Right: Detail panels */
  .nexus-material-lab__details {
    position: relative;
    min-height: 360px;
  }
  .nexus-material-lab__panel {
    display: none;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 36px;
    animation: nexus-fade-in .35s ease;
  }
  .nexus-material-lab__panel.is-active {
    display: block;
  }
  .nexus-material-lab__panel-title {
    font-size: 1.4rem;
    margin: 0 0 8px;
  }
  .nexus-material-lab__panel-desc {
    font-size: .9rem;
    color: var(--nx-body);
    line-height: 1.65;
    margin: 0 0 28px;
    max-width: 480px;
  }

  /* Progress bars */
  .nexus-material-lab__bars {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 28px;
  }
  .nexus-material-lab__bar-label {
    display: flex;
    justify-content: space-between;
    font-family: var(--nx-font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--nx-dark);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .03em;
  }
  .nexus-material-lab__bar-val {
    color: var(--nx-primary);
  }
  .nexus-material-lab__bar-track {
    width: 100%;
    height: 8px;
    background: var(--nx-outline);
    border-radius: 4px;
    overflow: hidden;
  }
  .nexus-material-lab__bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width .6s cubic-bezier(.22,1,.36,1);
  }

  .nexus-material-lab__meta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .nexus-material-lab__meta-chip {
    font-family: var(--nx-font-mono);
    font-size: 12px;
    padding: 6px 14px;
    background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    color: var(--nx-body);
  }
  .nexus-material-lab__meta-chip strong {
    color: var(--nx-dark);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .nexus-material-lab__grid {
      grid-template-columns: 1fr;
    }
    .nexus-material-lab__list {
      flex-direction: row;
      overflow-x: auto;
      gap: 8px;
      padding-bottom: 4px;
    }
    .nexus-material-lab__material {
      flex-shrink: 0;
      min-width: 160px;
    }
  }
</style>

{% schema %}
{
  "name": "Material Lab",
  "tag": "section",
  "class": "nexus-section-material-lab",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Material Lab"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore the properties of every filament and resin we stock."
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        { "type": "text", "id": "name", "label": "Material Name", "default": "PLA" },
        { "type": "text", "id": "type", "label": "Material Type", "default": "Filament" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "A versatile, eco-friendly thermoplastic perfect for prototyping and display models." },
        { "type": "color", "id": "color", "label": "Accent Color", "default": "#5C7285" },
        { "type": "range", "id": "strength", "label": "Strength (%)", "min": 0, "max": 100, "step": 5, "default": 55 },
        { "type": "range", "id": "flex", "label": "Flexibility (%)", "min": 0, "max": 100, "step": 5, "default": 35 },
        { "type": "range", "id": "heat", "label": "Heat Resistance (%)", "min": 0, "max": 100, "step": 5, "default": 40 },
        { "type": "range", "id": "detail", "label": "Detail Resolution (%)", "min": 0, "max": 100, "step": 5, "default": 75 },
        { "type": "text", "id": "layer_min", "label": "Minimum Layer Height", "default": "0.1mm" },
        { "type": "text", "id": "temp", "label": "Print Temperature", "default": "200°C" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Material Lab",
      "blocks": [
        { "type": "material", "settings": { "name": "PLA", "type": "Filament", "description": "A versatile, eco-friendly thermoplastic perfect for prototyping and display models. Easy to print with excellent detail.", "color": "#5C7285", "strength": 55, "flex": 35, "heat": 40, "detail": 80, "layer_min": "0.1mm", "temp": "200°C" } },
        { "type": "material", "settings": { "name": "Resin", "type": "SLA", "description": "Ultra-high detail liquid photopolymer for jewelry, dental, and miniatures. Cured with UV light for a smooth finish.", "color": "#8B6F47", "strength": 45, "flex": 15, "heat": 55, "detail": 95, "layer_min": "0.025mm", "temp": "N/A" } },
        { "type": "material", "settings": { "name": "Nylon", "type": "Filament", "description": "Industrial-grade polyamide with excellent impact resistance. Ideal for functional parts, gears, and living hinges.", "color": "#2D6A4F", "strength": 85, "flex": 75, "heat": 80, "detail": 55, "layer_min": "0.15mm", "temp": "260°C" } },
        { "type": "material", "settings": { "name": "PETG", "type": "Filament", "description": "A balanced material combining the ease of PLA with the durability of ABS. Chemical and moisture resistant.", "color": "#3B82F6", "strength": 70, "flex": 50, "heat": 65, "detail": 65, "layer_min": "0.12mm", "temp": "230°C" } }
      ]
    }
  ]
}
{% endschema %}
