{%- comment -%} NEXUS-3D · MAIN COLLECTION — Linen & Steel {%- endcomment -%}

<section class="nexus-collection nexus-section--compact">
  <div class="nexus-container">
    <div style="text-align:center; margin-bottom:40px;">
      <h1 style="font-family:var(--nx-font-heading); font-weight:800; font-size:clamp(1.8rem,3vw,2.8rem); color:var(--nx-dark); margin:0 0 12px;">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="font-size:1.05rem; color:var(--nx-body); max-width:540px; margin:0 auto; line-height:1.65;">{{ collection.description }}</p>
      {%- endif -%}
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:20px;">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" style="text-decoration:none;">
          <div style="background:var(--nx-bg); border:1px solid var(--nx-outline); border-radius:var(--nx-radius-xl); overflow:hidden; transition:transform .3s, box-shadow .3s; box-shadow:var(--nx-shadow-sm);" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='var(--nx-shadow-md)'" onmouseout="this.style.transform='';this.style.boxShadow='var(--nx-shadow-sm)'">
            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" style="width:100%; aspect-ratio:1; object-fit:cover;" loading="lazy">
            {%- endif -%}
            <div style="padding:20px;">
              <h3 style="font-family:var(--nx-font-heading); font-size:1rem; font-weight:700; color:var(--nx-dark); margin:0 0 6px;">{{ product.title }}</h3>
              <span style="font-family:var(--nx-font-mono); font-size:14px; color:var(--nx-primary); font-weight:700;">{{ product.price | money }}</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if collection.products.size == 0 -%}
      <p style="text-align:center; color:var(--nx-body); opacity:.5; padding:60px 0;">No products in this collection yet.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Collection",
  "tag": "section",
  "class": "nexus-section-collection",
  "settings": [],
  "templates": ["collection"]
}
{% endschema %}
