{%- comment -%}
  ============================================================
  NEXUS-3D  ·  SECTION: PROCESS FLOW (THE CYCLE)
  4-column layout: Upload → Analysis → Print → Delivery
  ============================================================
{%- endcomment -%}

<section class="nexus-process nexus-section" data-section-type="process-flow">
  <div class="nexus-process__inner nexus-container">

    <div class="nexus-process__header" data-nexus-animate>
      <h2 class="nexus-process__title">{{ section.settings.heading | default: 'How It Works' }}</h2>
      <p class="nexus-process__subtitle">{{ section.settings.subheading | default: 'From file to finished product in four simple steps.' }}</p>
    </div>

    <div class="nexus-process__grid">
      {%- for block in section.blocks -%}
        <div class="nexus-process__card" data-nexus-animate {{ block.shopify_attributes }}>
          <div class="nexus-process__step-number">{{ forloop.index }}</div>
          <div class="nexus-process__icon">
            {%- case block.settings.icon -%}
              {%- when 'upload' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              {%- when 'analysis' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              {%- when 'print' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              {%- when 'delivery' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- else -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- endcase -%}
          </div>
          <h3 class="nexus-process__card-title">{{ block.settings.title }}</h3>
          <p class="nexus-process__card-desc">{{ block.settings.description }}</p>

          {%- if forloop.last == false -%}
            <div class="nexus-process__connector" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .nexus-process__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .nexus-process__title {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    margin: 0 0 12px;
  }
  .nexus-process__subtitle {
    font-size: 1.05rem;
    color: var(--nx-body);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.65;
  }

  .nexus-process__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .nexus-process__card {
    position: relative;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 36px 28px;
    text-align: center;
    transition: box-shadow .3s, transform .3s;
  }
  .nexus-process__card:hover {
    box-shadow: var(--nx-shadow-md);
    transform: translateY(-2px);
  }

  .nexus-process__step-number {
    font-family: var(--nx-font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--nx-primary);
    background: var(--nx-primary-10);
    width: 28px; height: 28px;
    border-radius: var(--nx-radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    letter-spacing: .03em;
  }

  .nexus-process__icon {
    color: var(--nx-primary);
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
  }

  .nexus-process__card-title {
    font-size: 1.1rem;
    margin: 0 0 8px;
  }
  .nexus-process__card-desc {
    font-size: .85rem;
    color: var(--nx-body);
    line-height: 1.6;
    margin: 0;
  }

  /* Connector arrow between cards */
  .nexus-process__connector {
    position: absolute;
    right: -20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    color: var(--nx-outline);
  }

  @media (max-width: 960px) {
    .nexus-process__grid { grid-template-columns: 1fr 1fr; }
    .nexus-process__connector { display: none; }
  }
  @media (max-width: 640px) {
    .nexus-process__grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Process Flow",
  "tag": "section",
  "class": "nexus-section-process",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From file to finished product in four simple steps."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Upload" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Send us your STL, OBJ, or STEP file through our secure upload portal." },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "upload", "label": "Upload" },
            { "value": "analysis", "label": "Analysis" },
            { "value": "print", "label": "Print" },
            { "value": "delivery", "label": "Delivery" }
          ],
          "default": "upload"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Flow",
      "blocks": [
        { "type": "step", "settings": { "title": "Upload", "description": "Send us your STL, OBJ, or STEP file through our secure upload portal.", "icon": "upload" } },
        { "type": "step", "settings": { "title": "Analysis", "description": "Our engineers review your file, optimize orientation, and select the best material.", "icon": "analysis" } },
        { "type": "step", "settings": { "title": "Print", "description": "Your design is printed on industrial-grade machines with sub-millimeter precision.", "icon": "print" } },
        { "type": "step", "settings": { "title": "Delivery", "description": "Quality-checked, carefully packaged, and shipped directly to your door.", "icon": "delivery" } }
      ]
    }
  ]
}
{% endschema %}
