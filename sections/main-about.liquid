{%- comment -%}
  NEXUS-3D  ·  MAIN ABOUT — "About Us" page section
  Image + text storytelling layout
{%- endcomment -%}

<section class="nexus-about nexus-section" data-section-id="{{ section.id }}">
  <div class="nexus-container">

    <div class="nexus-about__header" data-nexus-animate>
      <span class="nexus-about__badge">[ABOUT US]</span>
      <h1 class="nexus-about__title">{{ section.settings.heading }}</h1>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'story_block' -%}
        <div class="nexus-about__row {% if forloop.index == 2 or forloop.index == 4 %}nexus-about__row--reverse{% endif %}" data-nexus-animate {{ block.shopify_attributes }}>
          <div class="nexus-about__image-col">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.block_heading | escape }}" loading="lazy" class="nexus-about__image">
            {%- else -%}
              <div class="nexus-about__image-placeholder"></div>
            {%- endif -%}
          </div>
          <div class="nexus-about__text-col">
            {%- if block.settings.block_label != blank -%}
              <span class="nexus-about__text-label">{{ block.settings.block_label }}</span>
            {%- endif -%}
            <h2 class="nexus-about__text-heading">{{ block.settings.block_heading }}</h2>
            <div class="nexus-about__text-body">{{ block.settings.block_text }}</div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Stats Bar {%- endcomment -%}
    {%- assign stats_exist = false -%}
    {%- for block in section.blocks -%}{%- if block.type == 'stat' -%}{%- assign stats_exist = true -%}{%- break -%}{%- endif -%}{%- endfor -%}
    {%- if stats_exist -%}
      <div class="nexus-about__stats" data-nexus-animate>
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="nexus-about__stat" {{ block.shopify_attributes }}>
              <span class="nexus-about__stat-value" data-counter-target="{{ block.settings.stat_value }}">0</span>
              <span class="nexus-about__stat-label">{{ block.settings.stat_label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} CTA {%- endcomment -%}
    {%- if section.settings.cta_text != blank -%}
      <div class="nexus-about__cta" data-nexus-animate>
        <a href="{{ section.settings.cta_link }}" class="nexus-btn nexus-btn--primary nexus-btn--lg">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .nexus-about__header { text-align: center; margin-bottom: 56px; }
  .nexus-about__badge {
    display: inline-block;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--nx-primary); margin-bottom: 12px;
  }
  .nexus-about__title { font-size: clamp(2rem, 5vw, 3.5rem); margin: 0; }

  .nexus-about__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: center;
    margin-bottom: 64px;
  }
  .nexus-about__row--reverse .nexus-about__image-col { order: 2; }
  .nexus-about__row--reverse .nexus-about__text-col { order: 1; }

  .nexus-about__image {
    width: 100%;
    border-radius: var(--nx-radius-xl);
    border: 1px solid var(--nx-outline);
    box-shadow: var(--nx-shadow-md);
  }
  .nexus-about__image-placeholder {
    width: 100%; aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--nx-surface), var(--nx-outline));
    border-radius: var(--nx-radius-xl);
  }

  .nexus-about__text-label {
    display: inline-block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--nx-primary); font-weight: 700;
    margin-bottom: 10px;
  }
  .nexus-about__text-heading {
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    margin: 0 0 16px;
  }
  .nexus-about__text-body {
    font-size: .92rem; color: var(--nx-body);
    line-height: 1.8;
  }

  .nexus-about__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 20px; margin: 40px 0 48px;
    padding: 40px;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
  }
  .nexus-about__stat { text-align: center; }
  .nexus-about__stat-value {
    display: block;
    font-family: var(--nx-font-heading); font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--nx-primary);
  }
  .nexus-about__stat-label {
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .55;
  }

  .nexus-about__cta { text-align: center; margin-top: 16px; }

  @media (max-width: 768px) {
    .nexus-about__row { grid-template-columns: 1fr; gap: 24px; }
    .nexus-about__row--reverse .nexus-about__image-col { order: 1; }
    .nexus-about__row--reverse .nexus-about__text-col { order: 2; }
  }
</style>

{% schema %}
{
  "name": "About Page",
  "tag": "section",
  "class": "nexus-section-about",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page Heading", "default": "About Nexus-3D" },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "Get a Quote" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "story_block",
      "name": "Story Section",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "block_label", "label": "Label", "default": "OUR STORY" },
        { "type": "text", "id": "block_heading", "label": "Heading", "default": "From Garage to Workshop" },
        { "type": "richtext", "id": "block_text", "label": "Body Text", "default": "<p>We started with a single 3D printer and a passion for making ideas real. Today, our workshop runs 12 printers across 4 technologies, delivering precision parts for engineers, designers and creators worldwide.</p>" }
      ]
    },
    {
      "type": "stat",
      "name": "Stat Counter",
      "settings": [
        { "type": "text", "id": "stat_value", "label": "Number Value", "default": "1200" },
        { "type": "text", "id": "stat_label", "label": "Label", "default": "Parts Delivered" }
      ]
    }
  ],
  "presets": [{
    "name": "About Page",
    "blocks": [
      { "type": "story_block", "settings": { "block_label": "OUR STORY", "block_heading": "From Garage to Workshop", "block_text": "<p>We started with a single 3D printer and a passion for making ideas real. Today, our workshop runs 12 printers across 4 technologies.</p>" }},
      { "type": "story_block", "settings": { "block_label": "OUR APPROACH", "block_heading": "Engineering-First Mindset", "block_text": "<p>Every file gets reviewed by our team before it hits the print bed. We check wall thickness, overhangs, and structural integrity to ensure your part comes out right the first time.</p>" }},
      { "type": "stat", "settings": { "stat_value": "1200", "stat_label": "Parts Delivered" }},
      { "type": "stat", "settings": { "stat_value": "12", "stat_label": "Printers Running" }},
      { "type": "stat", "settings": { "stat_value": "8", "stat_label": "Material Types" }},
      { "type": "stat", "settings": { "stat_value": "99", "stat_label": "% Uptime" }}
    ]
  }]
}
{% endschema %}
