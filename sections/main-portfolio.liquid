{%- comment -%}
  NEXUS-3D  ·  MAIN PORTFOLIO — "Our Work" page section
  Full-page masonry grid with category filtering
{%- endcomment -%}

<section class="nexus-portfolio nexus-section" data-section-id="{{ section.id }}">
  <div class="nexus-container">

    {%- comment -%} Page Header {%- endcomment -%}
    <div class="nexus-portfolio__header" data-nexus-animate>
      <span class="nexus-portfolio__badge">[PORTFOLIO]</span>
      <h1 class="nexus-portfolio__title">{{ section.settings.heading }}</h1>
      <p class="nexus-portfolio__subtitle">{{ section.settings.subheading }}</p>
    </div>

    {%- comment -%} Filter Pills {%- endcomment -%}
    <div class="nexus-portfolio__filters" data-nexus-animate>
      <button class="nexus-portfolio__pill is-active" data-filter="all">All Work</button>
      {%- for block in section.blocks -%}
        {%- if block.type == 'project' -%}
          {%- assign cat = block.settings.category | strip -%}
          {%- if cat != blank -%}
            <button class="nexus-portfolio__pill" data-filter="{{ cat | handleize }}">{{ cat }}</button>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Grid {%- endcomment -%}
    <div class="nexus-portfolio__grid" data-nexus-animate>
      {%- for block in section.blocks -%}
        {%- if block.type == 'project' -%}
          {%- assign cat = block.settings.category | handleize -%}
          <div class="nexus-portfolio__item nexus-portfolio__item--{{ block.settings.size }}" data-category="{{ cat }}" {{ block.shopify_attributes }}>
            <div class="nexus-portfolio__card">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
              {%- else -%}
                <div class="nexus-portfolio__card-placeholder"></div>
              {%- endif -%}
              <div class="nexus-portfolio__overlay">
                <span class="nexus-portfolio__cat-chip">{{ block.settings.category }}</span>
                <h3 class="nexus-portfolio__card-title">{{ block.settings.title }}</h3>
                <p class="nexus-portfolio__card-desc">{{ block.settings.description }}</p>
                <div class="nexus-portfolio__card-meta">
                  {%- if block.settings.material != blank -%}
                    <span class="nexus-portfolio__meta-chip">{{ block.settings.material }}</span>
                  {%- endif -%}
                  {%- if block.settings.time != blank -%}
                    <span class="nexus-portfolio__meta-chip">{{ block.settings.time }}</span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .nexus-portfolio__header { text-align: center; margin-bottom: 40px; }
  .nexus-portfolio__badge {
    display: inline-block;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--nx-primary); margin-bottom: 12px;
  }
  .nexus-portfolio__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 12px;
  }
  .nexus-portfolio__subtitle {
    font-size: 1.05rem; color: var(--nx-body); opacity: .65;
    max-width: 560px; margin: 0 auto; line-height: 1.65;
  }

  .nexus-portfolio__filters {
    display: flex; flex-wrap: wrap;
    justify-content: center; gap: 8px;
    margin-bottom: 40px;
  }
  .nexus-portfolio__pill {
    padding: 8px 20px;
    background: var(--nx-surface);
    color: var(--nx-body);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-heading); font-weight: 700;
    font-size: .8rem; cursor: pointer;
    transition: all .25s;
  }
  .nexus-portfolio__pill:hover,
  .nexus-portfolio__pill.is-active {
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    border-color: var(--nx-primary);
  }

  .nexus-portfolio__grid {
    columns: 3;
    column-gap: 20px;
  }
  .nexus-portfolio__item {
    break-inside: avoid;
    margin-bottom: 20px;
    transition: opacity .3s, transform .3s;
  }
  .nexus-portfolio__item.is-hidden {
    display: none;
  }
  .nexus-portfolio__card {
    position: relative;
    border-radius: var(--nx-radius-xl);
    overflow: hidden;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    box-shadow: var(--nx-shadow-sm);
    transition: transform .35s, box-shadow .35s;
  }
  .nexus-portfolio__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--nx-shadow-lg);
  }
  .nexus-portfolio__card img { width: 100%; display: block; }
  .nexus-portfolio__card-placeholder {
    width: 100%; aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--nx-surface), var(--nx-outline));
  }
  .nexus-portfolio__item--tall .nexus-portfolio__card img,
  .nexus-portfolio__item--tall .nexus-portfolio__card-placeholder { aspect-ratio: 3/5; object-fit: cover; }
  .nexus-portfolio__item--wide .nexus-portfolio__card img,
  .nexus-portfolio__item--wide .nexus-portfolio__card-placeholder { aspect-ratio: 16/9; object-fit: cover; }
  .nexus-portfolio__item--square .nexus-portfolio__card img,
  .nexus-portfolio__item--square .nexus-portfolio__card-placeholder { aspect-ratio: 1; object-fit: cover; }

  .nexus-portfolio__overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    background: linear-gradient(to top, rgba(253,252,251,.92), transparent 60%);
    opacity: 0; transition: opacity .3s;
  }
  .nexus-portfolio__card:hover .nexus-portfolio__overlay { opacity: 1; }

  .nexus-portfolio__cat-chip {
    align-self: flex-start;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    padding: 4px 12px;
    background: var(--nx-primary);
    color: var(--nx-on-primary);
    border-radius: var(--nx-radius-pill);
    margin-bottom: 8px;
  }
  .nexus-portfolio__card-title {
    font-family: var(--nx-font-heading); font-weight: 800;
    font-size: 1.1rem; color: var(--nx-dark); margin: 0 0 4px;
  }
  .nexus-portfolio__card-desc {
    font-size: .82rem; color: var(--nx-body);
    line-height: 1.5; margin: 0 0 8px;
  }
  .nexus-portfolio__card-meta { display: flex; gap: 6px; }
  .nexus-portfolio__meta-chip {
    font-family: var(--nx-font-mono); font-size: 10px;
    padding: 3px 10px;
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    color: var(--nx-body);
  }

  @media (max-width: 960px) { .nexus-portfolio__grid { columns: 2; } }
  @media (max-width: 640px) { .nexus-portfolio__grid { columns: 1; } }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var pills = document.querySelectorAll('.nexus-portfolio__pill');
    var items = document.querySelectorAll('.nexus-portfolio__item');
    pills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        pills.forEach(function (p) { p.classList.remove('is-active'); });
        pill.classList.add('is-active');
        var filter = pill.dataset.filter;
        items.forEach(function (item) {
          if (filter === 'all' || item.dataset.category === filter) {
            item.classList.remove('is-hidden');
          } else {
            item.classList.add('is-hidden');
          }
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Portfolio Grid",
  "tag": "section",
  "class": "nexus-section-portfolio",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Work" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Precision engineering meets creative design. Every project tells a story of innovation." }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Project Title" },
        { "type": "text", "id": "description", "label": "Short Description", "default": "Custom 3D printed component" },
        { "type": "text", "id": "category", "label": "Category", "default": "Functional" },
        { "type": "text", "id": "material", "label": "Material Tag", "default": "PLA" },
        { "type": "text", "id": "time", "label": "Time Tag", "default": "12h" },
        { "type": "select", "id": "size", "label": "Card Size", "default": "square", "options": [
          { "value": "tall", "label": "Tall" },
          { "value": "wide", "label": "Wide" },
          { "value": "square", "label": "Square" }
        ]}
      ]
    }
  ],
  "presets": [{
    "name": "Portfolio Grid",
    "blocks": [
      { "type": "project", "settings": { "title": "Drone Housing", "category": "Functional", "material": "Nylon", "time": "18h", "size": "tall" }},
      { "type": "project", "settings": { "title": "Architectural Model", "category": "Prototype", "material": "Resin", "time": "24h", "size": "wide" }},
      { "type": "project", "settings": { "title": "Custom Trophy", "category": "Creative", "material": "PLA", "time": "8h", "size": "square" }},
      { "type": "project", "settings": { "title": "Robotic Arm Joint", "category": "Functional", "material": "PETG", "time": "14h", "size": "square" }},
      { "type": "project", "settings": { "title": "PCB Enclosure", "category": "Functional", "material": "PLA", "time": "6h", "size": "wide" }},
      { "type": "project", "settings": { "title": "Cosplay Helmet", "category": "Creative", "material": "PLA", "time": "32h", "size": "tall" }}
    ]
  }]
}
{% endschema %}
