{%- comment -%} NEXUS-3D · FOOTER — Linen & Steel {%- endcomment -%}

<footer class="nexus-footer">
  <div class="nexus-footer__inner">
    <div class="nexus-footer__grid">

      {%- comment -%} Brand Column {%- endcomment -%}
      <div class="nexus-footer__col nexus-footer__col--brand">
        <span class="nexus-footer__brand">{{ shop.name }}</span>
        <p class="nexus-footer__tagline">{{ section.settings.tagline | default: 'Precision 3D printing for creators, engineers, and dreamers.' }}</p>

        {%- comment -%} Contact Info {%- endcomment -%}
        {%- if settings.contact_email != blank -%}
          <a href="mailto:{{ settings.contact_email }}" class="nexus-footer__contact-line">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            {{ settings.contact_email }}
          </a>
        {%- endif -%}
        {%- if settings.contact_phone != blank -%}
          <a href="tel:{{ settings.contact_phone | remove: ' ' }}" class="nexus-footer__contact-line">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {{ settings.contact_phone }}
          </a>
        {%- endif -%}

        <div class="nexus-footer__social" style="margin-top: 16px;">
          {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" class="nexus-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">IG</a>{%- endif -%}
          {%- if settings.social_twitter != blank -%}<a href="{{ settings.social_twitter }}" class="nexus-footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">X</a>{%- endif -%}
          {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" class="nexus-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">YT</a>{%- endif -%}
        </div>
      </div>

      {%- comment -%} Link Columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="nexus-footer__col" {{ block.shopify_attributes }}>
            <h4 class="nexus-footer__col-title">{{ block.settings.title }}</h4>
            <ul class="nexus-footer__links">
              {%- assign menu = block.settings.menu -%}
              {%- for link in menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="nexus-footer__bottom">
      <span class="nexus-footer__copy">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</span>
      <span class="nexus-footer__powered">Powered by Nexus-3D Theme</span>
    </div>
  </div>
</footer>

<style>
  .nexus-footer {
    background: var(--nx-surface);
    border-top: 1px solid var(--nx-outline);
    padding: 64px 32px 32px;
  }
  .nexus-footer__inner { max-width: 1440px; margin: 0 auto; }
  .nexus-footer__grid {
    display: grid;
    grid-template-columns: 2fr repeat(auto-fit, minmax(140px, 1fr));
    gap: 40px;
    margin-bottom: 48px;
  }
  .nexus-footer__brand {
    font-family: var(--nx-font-heading);
    font-weight: var(--nx-heading-weight, 800);
    font-size: 1.2rem;
    color: var(--nx-dark);
    letter-spacing: -.03em;
  }
  .nexus-footer__tagline {
    font-size: .85rem;
    color: var(--nx-body);
    margin: 12px 0 12px;
    line-height: 1.5;
    max-width: 280px;
  }
  .nexus-footer__contact-line {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--nx-font-mono); font-size: 12px;
    color: var(--nx-body); text-decoration: none;
    margin-bottom: 6px; transition: color .2s;
  }
  .nexus-footer__contact-line:hover { color: var(--nx-primary); }
  .nexus-footer__social { display: flex; gap: 8px; }
  .nexus-footer__social-link {
    font-family: var(--nx-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    color: var(--nx-body);
    text-decoration: none;
    transition: all .25s cubic-bezier(.2, 0, 0, 1);
  }
  .nexus-footer__social-link:hover {
    background: var(--nx-primary-06);
    border-color: var(--nx-primary);
    color: var(--nx-primary);
  }
  .nexus-footer__col-title {
    font-family: var(--nx-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--nx-primary);
    margin: 0 0 16px;
    font-weight: 700;
  }
  .nexus-footer__links { list-style: none; margin: 0; padding: 0; }
  .nexus-footer__links li { margin-bottom: 8px; }
  .nexus-footer__links a {
    font-size: .85rem;
    color: var(--nx-body);
    text-decoration: none;
    transition: color .2s;
  }
  .nexus-footer__links a:hover { color: var(--nx-primary); }
  .nexus-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--nx-outline);
    font-family: var(--nx-font-mono);
    font-size: 11px;
    color: var(--nx-body);
    opacity: .45;
  }

  @media (max-width: 768px) {
    .nexus-footer { padding: 40px 16px 24px; }
    .nexus-footer__grid { grid-template-columns: 1fr; gap: 32px; }
    .nexus-footer__bottom { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "class": "nexus-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Footer Tagline",
      "default": "Precision 3D printing for creators, engineers, and dreamers."
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ]
}
{% endschema %}
