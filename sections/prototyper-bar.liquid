{%- comment -%}
  ============================================================
  NEXUS-3D  ·  PROTOTYPER BAR
  Persistent floating sidebar with Upload STL + Request Quote
  ============================================================
{%- endcomment -%}

<aside class="nexus-prototyper" id="NexusPrototyper" aria-label="Quick actions">
  <div class="nexus-prototyper__inner">

    {%- comment -%} Logo mark {%- endcomment -%}
    <div class="nexus-prototyper__logo">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
        <path d="M2 17l10 5 10-5"/>
        <path d="M2 12l10 5 10-5"/>
      </svg>
    </div>

    {%- comment -%} Upload STL Button {%- endcomment -%}
    <a
      href="{{ settings.prototyper_upload_url | default: '#' }}"
      class="nexus-prototyper__btn nexus-prototyper__btn--upload"
      title="{{ settings.prototyper_cta_text }}"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
      <span class="nexus-prototyper__btn-label">{{ settings.prototyper_cta_text }}</span>
    </a>

    {%- comment -%} Request Quote Button {%- endcomment -%}
    <a
      href="{{ settings.prototyper_quote_url | default: '#' }}"
      class="nexus-prototyper__btn nexus-prototyper__btn--quote"
      title="{{ settings.prototyper_quote_text }}"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      <span class="nexus-prototyper__btn-label">{{ settings.prototyper_quote_text }}</span>
    </a>

    {%- comment -%} Cart indicator {%- endcomment -%}
    <a href="{{ routes.cart_url }}" class="nexus-prototyper__btn" title="Cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
      </svg>
      <span class="nexus-prototyper__cart-count">{{ cart.item_count }}</span>
    </a>

  </div>
</aside>

<style>
  .nexus-prototyper {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1000;
    padding: 8px;
  }
  .nexus-prototyper__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 8px;
    background: var(--nexus-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-xl);
    box-shadow: var(--m3-elevation-3);
  }

  .nexus-prototyper__logo {
    color: var(--nexus-accent);
    padding: 8px;
    margin-bottom: 4px;
  }

  .nexus-prototyper__btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border-radius: var(--m3-radius-full);
    background: transparent;
    color: var(--m3-on-surface-variant);
    text-decoration: none;
    transition: all .25s cubic-bezier(.2, 0, 0, 1);
  }
  .nexus-prototyper__btn:hover {
    background: rgba(208,188,255,.1);
    color: var(--nexus-accent);
  }
  .nexus-prototyper__btn--upload:hover {
    background: var(--nexus-accent);
    color: var(--m3-on-primary);
    box-shadow: var(--m3-elevation-2);
  }
  .nexus-prototyper__btn--quote:hover {
    background: rgba(208,188,255,.12);
    color: var(--nexus-accent);
  }

  .nexus-prototyper__btn-label {
    position: absolute;
    right: calc(100% + 12px);
    white-space: nowrap;
    font-family: var(--nexus-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .05em;
    padding: 6px 14px;
    background: var(--m3-surface-container-high);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-full);
    color: var(--nexus-text);
    opacity: 0;
    pointer-events: none;
    transform: translateX(8px);
    transition: all .2s;
    box-shadow: var(--m3-elevation-2);
  }
  .nexus-prototyper__btn:hover .nexus-prototyper__btn-label {
    opacity: 1;
    transform: translateX(0);
  }

  .nexus-prototyper__cart-count {
    position: absolute;
    top: 2px; right: 2px;
    min-width: 16px; height: 16px;
    border-radius: var(--m3-radius-full);
    background: var(--nexus-accent);
    color: var(--m3-on-primary);
    font-family: var(--nexus-font-mono);
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .nexus-prototyper {
      right: auto;
      left: 0;
      right: 0;
      top: auto;
      bottom: 0;
      transform: none;
      padding: 0;
    }
    .nexus-prototyper__inner {
      flex-direction: row;
      justify-content: center;
      border-radius: var(--m3-radius-xl) var(--m3-radius-xl) 0 0;
      padding: 10px 16px;
      width: 100%;
    }
    .nexus-prototyper__logo { display: none; }
    .nexus-prototyper__btn-label { display: none; }
  }
</style>

{% schema %}
{
  "name": "Prototyper Bar",
  "class": "nexus-prototyper-section",
  "settings": []
}
{% endschema %}
