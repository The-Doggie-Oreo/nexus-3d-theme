{%- comment -%}
  NEXUS-3D  ·  PROTOTYPER BAR — Linen & Steel
  Slim announcement / printer-status bar
{%- endcomment -%}

{%- liquid
  assign bar_enabled = section.settings.enable_bar
-%}

{%- if bar_enabled -%}
<div class="nexus-proto-bar" data-section-id="{{ section.id }}">
  <div class="nexus-proto-bar__inner">
    <div class="nexus-proto-bar__left">
      <span class="nexus-proto-bar__dot" style="background:{{ section.settings.status_color }}"></span>
      <span class="nexus-proto-bar__status">{{ section.settings.status_text }}</span>
    </div>
    <div class="nexus-proto-bar__right">
      <span class="nexus-proto-bar__announce">{{ section.settings.announcement }}</span>
    </div>
  </div>
</div>

<style>
  .nexus-proto-bar {
    background: var(--nx-dark);
    color: rgba(255,255,255,.85);
    font-family: var(--nx-font-mono);
    font-size: 11px;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .nexus-proto-bar__inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 7px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .nexus-proto-bar__left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nexus-proto-bar__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    animation: nexus-pulse 2s ease-in-out infinite;
  }
  @keyframes nexus-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .4; }
  }
  .nexus-proto-bar__status { font-weight: 700; }
  .nexus-proto-bar__announce { opacity: .65; }
  @media (max-width: 640px) {
    .nexus-proto-bar__inner { justify-content: center; text-align: center; }
    .nexus-proto-bar__right { display: none; }
  }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Prototyper Bar",
  "tag": "div",
  "class": "nexus-proto-bar-wrapper",
  "settings": [
    { "type": "checkbox", "id": "enable_bar", "label": "Enable Prototyper Bar", "default": true },
    { "type": "text", "id": "status_text", "label": "Status Text", "default": "PRINTERS ONLINE" },
    { "type": "color", "id": "status_color", "label": "Status Dot Color", "default": "#2D6A4F" },
    { "type": "text", "id": "announcement", "label": "Announcement", "default": "Free shipping on orders over £50" }
  ],
  "templates": ["index", "product", "collection", "page", "cart"]
}
{% endschema %}
