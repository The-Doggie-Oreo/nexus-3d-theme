{%- comment -%}
  NEXUS-3D  ·  PRODUCT — TECH SPECS (Linen & Steel)
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<section class="nexus-product nexus-section--compact" data-section-id="{{ section.id }}">
  <div class="nexus-product__grid nexus-container">

    {%- comment -%} LEFT: Gallery {%- endcomment -%}
    <div class="nexus-product__gallery">
      <div class="nexus-product__main-image">
        {%- if product.featured_image != blank -%}
          <img id="ProductMainImage" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
        {%- else -%}
          <div class="nexus-product__placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="nexus-product__thumbs">
          {%- for image in product.images -%}
            <button class="nexus-product__thumb {% if forloop.first %}is-active{% endif %}" data-image-url="{{ image | image_url: width: 1200 }}">
              <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}" width="60" height="60" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: Info {%- endcomment -%}
    <div class="nexus-product__info">
      <nav class="nexus-product__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span>/</span>
        {%- if product.collections.size > 0 -%}
          <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
          <span>/</span>
        {%- endif -%}
        <span>{{ product.title }}</span>
      </nav>

      <h1 class="nexus-product__title">{{ product.title }}</h1>
      <div class="nexus-product__price">
        <span class="nexus-product__price-current">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="nexus-product__price-compare">{{ current_variant.compare_at_price | money }}</span>
        {%- endif -%}
      </div>

      <div class="nexus-product__description">{{ product.description }}</div>

      {%- comment -%} Tech Specs {%- endcomment -%}
      <div class="nexus-techspecs">
        <div class="nexus-techspecs__header">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span>Technical Specifications</span>
        </div>
        <div class="nexus-techspecs__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'spec' -%}
              <div class="nexus-techspecs__item" {{ block.shopify_attributes }}>
                <span class="nexus-techspecs__label">{{ block.settings.spec_label }}</span>
                <span class="nexus-techspecs__value">{{ block.settings.spec_value }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- assign materials_exist = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'material_option' -%}{%- assign materials_exist = true -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
        {%- if materials_exist -%}
          <div class="nexus-techspecs__materials">
            <span class="nexus-techspecs__mat-label">Available Materials</span>
            <div class="nexus-techspecs__mat-chips">
              {%- for block in section.blocks -%}
                {%- if block.type == 'material_option' -%}
                  <span class="nexus-techspecs__mat-chip" {{ block.shopify_attributes }}>
                    <span class="nexus-techspecs__mat-dot" style="background: {{ block.settings.material_color }}"></span>
                    {{ block.settings.material_name }}
                  </span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- form 'product', product -%}
        {%- if product.variants.size > 1 -%}
          <div class="nexus-product__variants">
            {%- for option in product.options_with_values -%}
              <div class="nexus-product__option">
                <label class="nexus-product__option-label">{{ option.name }}</label>
                <select name="id" class="nexus-personalization__select">
                  {%- for variant in product.variants -%}
                    <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %}>
                      {{ variant.title }} — {{ variant.price | money }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- endif -%}

        {% render 'snippet-personalization-engine' %}

        <div class="nexus-product__atc-row">
          <div class="nexus-product__qty">
            <button type="button" class="nexus-product__qty-btn" data-action="decrease" aria-label="Decrease quantity">−</button>
            <input type="number" name="quantity" value="1" min="1" class="nexus-product__qty-input" aria-label="Quantity">
            <button type="button" class="nexus-product__qty-btn" data-action="increase" aria-label="Increase quantity">+</button>
          </div>
          <button type="submit" class="nexus-btn nexus-btn--primary nexus-btn--full" {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .nexus-product__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .nexus-product__main-image {
    background: var(--nx-surface);
    border-radius: var(--nx-radius-xl);
    overflow: hidden;
    border: 1px solid var(--nx-outline);
  }
  .nexus-product__main-image img { width: 100%; display: block; }
  .nexus-product__placeholder {
    display: flex; align-items: center; justify-content: center;
    height: 400px; color: var(--nx-body); opacity: .15;
  }
  .nexus-product__placeholder svg { width: 64px; height: 64px; }
  .nexus-product__thumbs { display: flex; gap: 8px; margin-top: 12px; }
  .nexus-product__thumb {
    width: 64px; height: 64px;
    border-radius: var(--nx-radius-md); overflow: hidden;
    border: 2px solid var(--nx-outline);
    cursor: pointer; background: none; padding: 0;
    transition: border-color .2s;
  }
  .nexus-product__thumb.is-active,
  .nexus-product__thumb:hover { border-color: var(--nx-primary); }
  .nexus-product__thumb img { width: 100%; height: 100%; object-fit: cover; }

  .nexus-product__breadcrumb {
    display: flex; gap: 6px; align-items: center;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .04em;
    color: var(--nx-body); opacity: .55;
    margin-bottom: 16px;
  }
  .nexus-product__breadcrumb a { color: inherit; text-decoration: none; }
  .nexus-product__breadcrumb a:hover { color: var(--nx-primary); opacity: 1; }

  .nexus-product__title {
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    margin: 0 0 12px;
  }
  .nexus-product__price { margin-bottom: 20px; display: flex; gap: 10px; align-items: baseline; }
  .nexus-product__price-current {
    font-family: var(--nx-font-heading);
    font-weight: 800; font-size: 1.5rem;
    color: var(--nx-primary);
  }
  .nexus-product__price-compare {
    font-size: 1rem; color: var(--nx-body); opacity: .4;
    text-decoration: line-through;
  }
  .nexus-product__description {
    font-size: .9rem; color: var(--nx-body);
    line-height: 1.7; margin-bottom: 24px;
  }

  .nexus-techspecs {
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 24px; margin-bottom: 24px;
  }
  .nexus-techspecs__header {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--nx-font-mono); font-size: 12px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-primary); font-weight: 700;
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--nx-outline);
  }
  .nexus-techspecs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px; margin-bottom: 16px;
  }
  .nexus-techspecs__item {
    display: flex; flex-direction: column; gap: 4px;
    padding: 14px; background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-md);
    transition: box-shadow .2s;
  }
  .nexus-techspecs__item:hover { box-shadow: var(--nx-shadow-sm); }
  .nexus-techspecs__label {
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .6;
  }
  .nexus-techspecs__value {
    font-family: var(--nx-font-mono); font-size: 14px;
    font-weight: 700; color: var(--nx-dark);
  }
  .nexus-techspecs__materials {
    padding-top: 16px;
    border-top: 1px solid var(--nx-outline);
  }
  .nexus-techspecs__mat-label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .5; margin-bottom: 10px;
  }
  .nexus-techspecs__mat-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .nexus-techspecs__mat-chip {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--nx-font-mono); font-size: 12px;
    padding: 6px 14px; background: var(--nx-bg);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    color: var(--nx-dark); transition: box-shadow .2s;
  }
  .nexus-techspecs__mat-chip:hover { box-shadow: var(--nx-shadow-sm); }
  .nexus-techspecs__mat-dot { width: 8px; height: 8px; border-radius: 50%; }

  .nexus-product__variants { margin-bottom: 16px; }
  .nexus-product__option { margin-bottom: 12px; }
  .nexus-product__option-label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .6; margin-bottom: 6px;
  }

  .nexus-product__atc-row { display: flex; gap: 12px; margin-top: 20px; }
  .nexus-product__qty {
    display: flex; align-items: center;
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    overflow: hidden;
  }
  .nexus-product__qty-btn {
    width: 44px; height: 48px;
    background: var(--nx-surface); color: var(--nx-dark);
    border: none; cursor: pointer; font-size: 18px;
    transition: all .2s;
  }
  .nexus-product__qty-btn:hover {
    background: var(--nx-primary);
    color: var(--nx-on-primary);
  }
  .nexus-product__qty-input {
    width: 52px; height: 48px; text-align: center;
    background: var(--nx-bg); color: var(--nx-dark);
    border: none;
    border-left: 1px solid var(--nx-outline);
    border-right: 1px solid var(--nx-outline);
    font-family: var(--nx-font-mono); font-size: 14px;
    -moz-appearance: textfield;
  }
  .nexus-product__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  @media (max-width: 960px) {
    .nexus-product__grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.nexus-product__qty-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var input = btn.closest('.nexus-product__qty').querySelector('.nexus-product__qty-input');
        var val = parseInt(input.value, 10) || 1;
        if (btn.dataset.action === 'increase') input.value = val + 1;
        else if (btn.dataset.action === 'decrease' && val > 1) input.value = val - 1;
      });
    });
    document.querySelectorAll('.nexus-product__thumb').forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var mainImg = document.getElementById('ProductMainImage');
        if (mainImg) mainImg.src = thumb.dataset.imageUrl;
        document.querySelectorAll('.nexus-product__thumb').forEach(function (t) { t.classList.remove('is-active'); });
        thumb.classList.add('is-active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product — Tech Specs",
  "tag": "section",
  "class": "nexus-section-product",
  "settings": [],
  "blocks": [
    {
      "type": "spec",
      "name": "Tech Spec",
      "settings": [
        { "type": "text", "id": "spec_label", "label": "Spec Label", "default": "Layer Height" },
        { "type": "text", "id": "spec_value", "label": "Spec Value", "default": "0.1mm" }
      ]
    },
    {
      "type": "material_option",
      "name": "Material Option",
      "settings": [
        { "type": "text", "id": "material_name", "label": "Material Name", "default": "PLA" },
        { "type": "color", "id": "material_color", "label": "Swatch Color", "default": "#5C7285" }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
