{%- comment -%}
  ============================================================
  NEXUS-3D  ·  SNIPPET: PERSONALIZATION ENGINE
  Forces onto every product page:
    1. "Design Notes" — rich text area for client instructions
    2. "Reference File" — file upload button (STL, OBJ, STEP, images)
  Uses Shopify Cart Attributes + Line Item Properties.
  Include this snippet with: {% render 'snippet-personalization-engine' %}
  ============================================================
{%- endcomment -%}

<div class="nexus-personalization" id="NexusPersonalization">
  <div class="nexus-personalization__header">
    <div class="nexus-personalization__icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 20h9"/>
        <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
    </div>
    <div>
      <h3 class="nexus-personalization__title">Personalize Your Print</h3>
      <p class="nexus-personalization__desc">Add notes for our engineers and upload your reference files.</p>
    </div>
  </div>

  {%- comment -%} ── 1. Design Notes Text Area ── {%- endcomment -%}
  <div class="nexus-personalization__field">
    <label class="nexus-personalization__label" for="design-notes-{{ product.id }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      Design Notes
      <span class="nexus-personalization__optional">(optional)</span>
    </label>
    <textarea
      id="design-notes-{{ product.id }}"
      name="properties[Design Notes]"
      class="nexus-personalization__textarea"
      placeholder="e.g. Scale to 150%, use matte finish, orient face-up for best surface quality..."
      rows="4"
      maxlength="2000"
    ></textarea>
    <div class="nexus-personalization__char-count">
      <span id="char-count-{{ product.id }}">0</span> / 2000
    </div>
  </div>

  {%- comment -%} ── 2. Reference File Upload ── {%- endcomment -%}
  <div class="nexus-personalization__field">
    <label class="nexus-personalization__label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Reference File
      <span class="nexus-personalization__optional">(optional)</span>
    </label>

    <div class="nexus-personalization__upload-zone" id="upload-zone-{{ product.id }}">
      <input
        type="file"
        id="ref-file-{{ product.id }}"
        class="nexus-personalization__file-input"
        accept=".stl,.obj,.step,.stp,.3mf,.png,.jpg,.jpeg,.pdf,.zip"
        aria-label="Upload reference file"
      >
      <div class="nexus-personalization__upload-content">
        <div class="nexus-personalization__upload-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <span class="nexus-personalization__upload-text">
          Drag & drop or <strong>click to browse</strong>
        </span>
        <span class="nexus-personalization__upload-formats">
          STL · OBJ · STEP · 3MF · PNG · JPG · PDF · ZIP
        </span>
        <span class="nexus-personalization__upload-size">Max 20 MB</span>
      </div>
    </div>

    {%- comment -%} File Preview (hidden until file selected) {%- endcomment -%}
    <div class="nexus-personalization__file-preview" id="file-preview-{{ product.id }}" style="display:none;">
      <div class="nexus-personalization__file-info">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
        <span class="nexus-personalization__file-name" id="file-name-{{ product.id }}"></span>
        <span class="nexus-personalization__file-size" id="file-size-{{ product.id }}"></span>
      </div>
      <button type="button" class="nexus-personalization__file-remove" id="file-remove-{{ product.id }}" aria-label="Remove file">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    {%- comment -%}
      Hidden input stores file URL after upload.
      Uses Shopify's file upload API or a third-party service.
    {%- endcomment -%}
    <input
      type="hidden"
      name="properties[Reference File URL]"
      id="ref-file-url-{{ product.id }}"
      value=""
    >
  </div>

  {%- comment -%} ── 3. Quick Spec Selections ── {%- endcomment -%}
  <div class="nexus-personalization__field">
    <label class="nexus-personalization__label">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      Print Preferences
    </label>
    <div class="nexus-personalization__preferences">
      <div class="nexus-personalization__pref-group">
        <span class="nexus-personalization__pref-label">Priority</span>
        <select name="properties[Priority]" class="nexus-personalization__select">
          <option value="Standard">Standard (5-7 days)</option>
          <option value="Rush">Rush (2-3 days)</option>
          <option value="Same Day">Same Day</option>
        </select>
      </div>
      <div class="nexus-personalization__pref-group">
        <span class="nexus-personalization__pref-label">Finish</span>
        <select name="properties[Finish]" class="nexus-personalization__select">
          <option value="Raw">Raw Print</option>
          <option value="Sanded">Sanded</option>
          <option value="Primed">Primed</option>
          <option value="Painted">Painted</option>
        </select>
      </div>
    </div>
  </div>
</div>

<style>
  /* ================================================
     PERSONALIZATION ENGINE — M3 Scoped Styles
     ================================================ */
  .nexus-personalization {
    background: var(--m3-surface-container-high);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-xl);
    padding: 28px;
    margin-top: 24px;
  }

  .nexus-personalization__header {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--m3-outline-variant);
  }
  .nexus-personalization__icon {
    flex-shrink: 0;
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(208,188,255,.1);
    border: 1px solid rgba(208,188,255,.15);
    border-radius: var(--m3-radius-md);
    color: var(--nexus-accent);
  }
  .nexus-personalization__title {
    font-family: var(--nexus-font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 4px;
  }
  .nexus-personalization__desc {
    font-size: .85rem;
    color: var(--m3-on-surface-variant);
    margin: 0;
  }

  /* Fields */
  .nexus-personalization__field {
    margin-bottom: 20px;
  }
  .nexus-personalization__field:last-child { margin-bottom: 0; }

  .nexus-personalization__label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--nexus-font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--m3-on-surface-variant);
    margin-bottom: 8px;
  }
  .nexus-personalization__optional {
    font-family: var(--nexus-font-body);
    text-transform: none;
    letter-spacing: 0;
    opacity: .45;
    font-size: 11px;
  }

  /* Textarea — M3 */
  .nexus-personalization__textarea {
    width: 100%;
    padding: 14px 16px;
    background: var(--m3-surface-container);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-lg);
    color: var(--nexus-text);
    font-family: var(--nexus-font-mono);
    font-size: 13px;
    line-height: 1.6;
    resize: vertical;
    transition: border-color .2s, box-shadow .2s;
    box-sizing: border-box;
  }
  .nexus-personalization__textarea:focus {
    outline: none;
    border-color: var(--nexus-accent);
    box-shadow: 0 0 0 3px rgba(208,188,255,.15);
  }
  .nexus-personalization__textarea::placeholder { color: var(--m3-on-surface-variant); opacity: .4; }

  .nexus-personalization__char-count {
    text-align: right;
    font-family: var(--nexus-font-mono);
    font-size: 11px;
    color: var(--m3-on-surface-variant);
    opacity: .4;
    margin-top: 4px;
  }

  /* Upload Zone — M3 */
  .nexus-personalization__upload-zone {
    position: relative;
    border: 2px dashed var(--m3-outline-variant);
    border-radius: var(--m3-radius-xl);
    padding: 32px 24px;
    text-align: center;
    cursor: pointer;
    transition: all .25s;
  }
  .nexus-personalization__upload-zone:hover,
  .nexus-personalization__upload-zone.is-dragover {
    border-color: var(--nexus-accent);
    background: rgba(208,188,255,.04);
  }
  .nexus-personalization__file-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  .nexus-personalization__upload-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    pointer-events: none;
  }
  .nexus-personalization__upload-icon { color: var(--nexus-accent); opacity: .6; }
  .nexus-personalization__upload-text {
    font-size: .9rem;
    color: var(--nexus-text);
  }
  .nexus-personalization__upload-text strong { color: var(--nexus-accent); }
  .nexus-personalization__upload-formats {
    font-family: var(--nexus-font-mono);
    font-size: 10px;
    color: var(--m3-on-surface-variant);
    opacity: .5;
    letter-spacing: .04em;
  }
  .nexus-personalization__upload-size {
    font-family: var(--nexus-font-mono);
    font-size: 10px;
    color: var(--m3-on-surface-variant);
    opacity: .3;
  }

  /* File Preview — M3 */
  .nexus-personalization__file-preview {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: rgba(208,188,255,.06);
    border: 1px solid rgba(208,188,255,.15);
    border-radius: var(--m3-radius-lg);
    margin-top: 8px;
  }
  .nexus-personalization__file-info {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--nexus-accent);
  }
  .nexus-personalization__file-name {
    font-family: var(--nexus-font-mono);
    font-size: 13px;
    color: #fff;
  }
  .nexus-personalization__file-size {
    font-family: var(--nexus-font-mono);
    font-size: 11px;
    color: var(--m3-on-surface-variant);
    opacity: .5;
  }
  .nexus-personalization__file-remove {
    background: none;
    border: none;
    color: var(--m3-on-surface-variant);
    opacity: .5;
    cursor: pointer;
    padding: 4px;
    transition: opacity .2s;
  }
  .nexus-personalization__file-remove:hover { opacity: 1; color: #ef4444; }

  /* Preferences — M3 */
  .nexus-personalization__preferences {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .nexus-personalization__pref-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nexus-personalization__pref-label {
    font-family: var(--nexus-font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--m3-on-surface-variant);
    opacity: .6;
  }
  .nexus-personalization__select {
    width: 100%;
    padding: 10px 12px;
    background: var(--m3-surface-container);
    border: 1px solid var(--m3-outline-variant);
    border-radius: var(--m3-radius-lg);
    color: var(--nexus-text);
    font-family: var(--nexus-font-mono);
    font-size: 12px;
    cursor: pointer;
    transition: border-color .2s;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23CAC4D0' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 12px center;
    padding-right: 32px;
  }
  .nexus-personalization__select:focus {
    outline: none;
    border-color: var(--nexus-accent);
  }

  @media (max-width: 640px) {
    .nexus-personalization { padding: 20px 16px; }
    .nexus-personalization__preferences { grid-template-columns: 1fr; }
  }
</style>

<script>
  (function () {
    var productId = '{{ product.id }}';
    var textarea  = document.getElementById('design-notes-' + productId);
    var charCount = document.getElementById('char-count-' + productId);
    var fileInput = document.getElementById('ref-file-' + productId);
    var uploadZone = document.getElementById('upload-zone-' + productId);
    var filePreview = document.getElementById('file-preview-' + productId);
    var fileName  = document.getElementById('file-name-' + productId);
    var fileSize  = document.getElementById('file-size-' + productId);
    var fileRemove = document.getElementById('file-remove-' + productId);
    var fileUrl   = document.getElementById('ref-file-url-' + productId);

    /* Character count */
    if (textarea && charCount) {
      textarea.addEventListener('input', function () {
        charCount.textContent = textarea.value.length;
      });
    }

    /* File upload handling */
    if (fileInput && uploadZone) {
      /* Drag & drop visual feedback */
      ['dragenter', 'dragover'].forEach(function (evt) {
        uploadZone.addEventListener(evt, function (e) {
          e.preventDefault();
          uploadZone.classList.add('is-dragover');
        });
      });
      ['dragleave', 'drop'].forEach(function (evt) {
        uploadZone.addEventListener(evt, function (e) {
          e.preventDefault();
          uploadZone.classList.remove('is-dragover');
        });
      });

      /* Show file preview */
      fileInput.addEventListener('change', function () {
        if (fileInput.files && fileInput.files[0]) {
          var file = fileInput.files[0];
          if (file.size > 20 * 1024 * 1024) {
            alert('File must be under 20 MB.');
            fileInput.value = '';
            return;
          }
          fileName.textContent = file.name;
          fileSize.textContent = (file.size / (1024 * 1024)).toFixed(2) + ' MB';
          filePreview.style.display = 'flex';
          uploadZone.style.display = 'none';

          /*
           * Production note: In a live store, you would upload the file
           * to Shopify Files API or a third-party service (e.g. Uploadcare)
           * and set fileUrl.value to the returned URL.
           * For now we store the filename as the line item property.
           */
          fileUrl.value = file.name;
        }
      });

      /* Remove file */
      if (fileRemove) {
        fileRemove.addEventListener('click', function () {
          fileInput.value = '';
          filePreview.style.display = 'none';
          uploadZone.style.display = '';
          fileUrl.value = '';
        });
      }
    }
  })();
</script>
