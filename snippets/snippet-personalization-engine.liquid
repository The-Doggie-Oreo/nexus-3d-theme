{%- comment -%}
  NEXUS-3D  ·  PERSONALIZATION ENGINE SNIPPET — Linen & Steel
  Renders on product page: print scale, color, file upload, notes
{%- endcomment -%}

<div class="nexus-personalization">
  <div class="nexus-personalization__head">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
    <span>Customization</span>
  </div>

  <div class="nexus-personalization__fields">
    {%- comment -%} Scale {%- endcomment -%}
    <div class="nexus-personalization__field">
      <label class="nexus-personalization__label" for="NexusScale">Print Scale</label>
      <select id="NexusScale" name="properties[Print Scale]" class="nexus-personalization__select">
        <option value="100%">100% — Original</option>
        <option value="75%">75%</option>
        <option value="50%">50%</option>
        <option value="150%">150%</option>
        <option value="200%">200%</option>
      </select>
    </div>

    {%- comment -%} Color {%- endcomment -%}
    <div class="nexus-personalization__field">
      <label class="nexus-personalization__label" for="NexusColor">Print Color</label>
      <select id="NexusColor" name="properties[Print Color]" class="nexus-personalization__select">
        <option value="Black">Black</option>
        <option value="White">White</option>
        <option value="Grey">Grey</option>
        <option value="Red">Red</option>
        <option value="Blue">Blue</option>
        <option value="Green">Green</option>
        <option value="Natural">Natural</option>
      </select>
    </div>

    {%- comment -%} File Upload {%- endcomment -%}
    <div class="nexus-personalization__field">
      <label class="nexus-personalization__label">Upload 3D File</label>
      <div class="nexus-personalization__upload-zone" id="PersonalizationDropzone">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nx-primary)" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span>Drop file or click to browse</span>
        <span style="font-size:10px; opacity:.45;">STL · OBJ · STEP</span>
      </div>
    </div>

    {%- comment -%} Notes {%- endcomment -%}
    <div class="nexus-personalization__field">
      <label class="nexus-personalization__label" for="NexusNotes">Special Notes</label>
      <textarea id="NexusNotes" name="properties[Notes]" rows="3" class="nexus-personalization__textarea" placeholder="Any special requirements..."></textarea>
    </div>
  </div>
</div>

<style>
  .nexus-personalization {
    background: var(--nx-surface);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-xl);
    padding: 24px;
    margin-bottom: 16px;
  }
  .nexus-personalization__head {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--nx-font-mono); font-size: 12px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-primary); font-weight: 700;
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--nx-outline);
  }
  .nexus-personalization__fields { display: flex; flex-direction: column; gap: 14px; }
  .nexus-personalization__field {}
  .nexus-personalization__label {
    display: block;
    font-family: var(--nx-font-mono); font-size: 10px;
    text-transform: uppercase; letter-spacing: .06em;
    color: var(--nx-body); opacity: .55;
    margin-bottom: 6px;
  }
  .nexus-personalization__select {
    width: 100%; padding: 10px 14px;
    background: var(--nx-bg); color: var(--nx-dark);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-pill);
    font-family: var(--nx-font-mono); font-size: 13px;
    appearance: none; cursor: pointer;
    transition: border-color .2s;
  }
  .nexus-personalization__select:focus {
    outline: none;
    border-color: var(--nx-primary);
    box-shadow: 0 0 0 3px var(--nx-primary-10);
  }
  .nexus-personalization__textarea {
    width: 100%; padding: 12px 14px;
    background: var(--nx-bg); color: var(--nx-dark);
    border: 1px solid var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    font-family: var(--nx-font-body); font-size: 13px;
    resize: vertical; transition: border-color .2s;
  }
  .nexus-personalization__textarea:focus {
    outline: none;
    border-color: var(--nx-primary);
    box-shadow: 0 0 0 3px var(--nx-primary-10);
  }
  .nexus-personalization__upload-zone {
    display: flex; flex-direction: column;
    align-items: center; gap: 6px;
    padding: 20px; text-align: center;
    border: 2px dashed var(--nx-outline);
    border-radius: var(--nx-radius-lg);
    font-family: var(--nx-font-mono); font-size: 12px;
    color: var(--nx-body); cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .nexus-personalization__upload-zone:hover {
    border-color: var(--nx-primary);
    background: var(--nx-primary-04);
  }
</style>
