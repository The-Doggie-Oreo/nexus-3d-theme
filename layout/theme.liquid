<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" dir="{{ request.locale.text_layout_strategy }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}{{ page_title }} — {{ shop.name }}{%- else -%}{{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} ===== Fonts: Outfit + JetBrains Mono ===== {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

  {%- comment -%} ===== Theme CSS ===== {%- endcomment -%}
  {{ 'nexus-core.css' | asset_url | stylesheet_tag }}

  {%- comment -%} ===== Shopify Defaults ===== {%- endcomment -%}
  {{ content_for_header }}

  {%- comment -%} ===== Linen & Steel Design Tokens ===== {%- endcomment -%}
  <style>
    :root {
      /* ── Linen & Steel Palette ── */
      --nx-primary:       {{ settings.color_primary }};
      --nx-on-primary:    {{ settings.color_on_primary }};
      --nx-bg:            {{ settings.color_background }};
      --nx-surface:       {{ settings.color_surface }};
      --nx-outline:       {{ settings.color_outline }};
      --nx-dark:          {{ settings.color_dark }};
      --nx-body:          {{ settings.color_body_text }};

      /* ── Derived Tones ── */
      --nx-primary-hover: #4A6070;
      --nx-surface-hover: #E8E7E3;
      --nx-primary-10:    rgba(92, 114, 133, 0.10);
      --nx-primary-06:    rgba(92, 114, 133, 0.06);
      --nx-primary-04:    rgba(92, 114, 133, 0.04);

      /* ── Typography ── */
      --nx-font-body:     'Outfit', {{ settings.font_body.family }}, sans-serif;
      --nx-font-heading:  'Outfit', {{ settings.font_heading.family }}, sans-serif;
      --nx-font-mono:     'JetBrains Mono', monospace;
      --nx-font-size:     {{ settings.font_body_size }}px;
      --nx-heading-weight: 800;
      --nx-body-weight:    500;
      --nx-label-weight:   700;

      /* ── Shape System ── */
      --nx-radius-xl:     32px;
      --nx-radius-lg:     24px;
      --nx-radius-md:     16px;
      --nx-radius-sm:     8px;
      --nx-radius-pill:   999px;

      /* ── Glassmorphism ── */
      --nx-glass:         rgba(253, 252, 251, 0.80);
      --nx-glass-border:  rgba(225, 226, 229, 0.60);

      /* ── Soft Elevation ── */
      --nx-shadow-sm:     0 1px 6px rgba(0,0,0,0.02);
      --nx-shadow-md:     0 4px 20px rgba(0,0,0,0.03);
      --nx-shadow-lg:     0 8px 32px rgba(0,0,0,0.05);
      --nx-shadow-xl:     0 12px 48px rgba(0,0,0,0.06);
    }
  </style>
</head>

<body class="nexus-body template-{{ template.name | handle }}">

  {%- comment -%} ===== Skip to Content ===== {%- endcomment -%}
  <a class="nexus-skip-link" href="#MainContent">Skip to content</a>

  {%- comment -%} ===== Prototyper Sidebar ===== {%- endcomment -%}
  {% if settings.prototyper_enabled %}
    {% section 'prototyper-bar' %}
  {% endif %}

  {%- comment -%} ===== Header ===== {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} ===== Main Content ===== {%- endcomment -%}
  <main id="MainContent" class="nexus-main" role="main">
    {{ content_for_layout }}
  </main>

  {%- comment -%} ===== Designer Workbench Panel ===== {%- endcomment -%}
  {% if settings.workbench_enabled %}
    {% section 'designer-workbench' %}
  {% endif %}

  {%- comment -%} ===== Footer ===== {%- endcomment -%}
  {% section 'footer' %}

  {%- comment -%} ===== Theme JS ===== {%- endcomment -%}
  <script src="{{ 'nexus-core.js' | asset_url }}" defer></script>

</body>
</html>
