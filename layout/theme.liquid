<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" dir="{{ request.locale.text_layout_strategy }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}{{ page_title }} — {{ shop.name }}{%- else -%}{{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} ===== Fonts ===== {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

  {%- comment -%} ===== Theme CSS ===== {%- endcomment -%}
  {{ 'nexus-core.css' | asset_url | stylesheet_tag }}

  {%- comment -%} ===== Shopify Defaults ===== {%- endcomment -%}
  {{ content_for_header }}

  {%- comment -%} ===== CSS Custom Properties from settings ===== {%- endcomment -%}
  <style>
    :root {
      /* ── M3 Core Tokens ── */
      --nexus-bg:        {{ settings.color_primary_bg }};
      --nexus-accent:    {{ settings.color_accent }};
      --nexus-text:      {{ settings.color_text }};
      --nexus-surface:   {{ settings.color_surface }};
      --nexus-border:    {{ settings.color_border }};

      /* ── M3 Extended Palette ── */
      --m3-primary:      #D0BCFF;
      --m3-on-primary:   #381E72;
      --m3-primary-container: #4F378B;
      --m3-on-primary-container: #EADDFF;
      --m3-surface-variant: #49454F;
      --m3-on-surface-variant: #CAC4D0;
      --m3-surface-container: #211F26;
      --m3-surface-container-high: #2B2930;
      --m3-outline: #938F99;
      --m3-outline-variant: #49454F;

      /* ── Typography ── */
      --nexus-font-body: 'Inter', {{ settings.font_body.family }}, sans-serif;
      --nexus-font-heading: 'Inter', {{ settings.font_heading.family }}, sans-serif;
      --nexus-font-mono: 'JetBrains Mono', monospace;
      --nexus-font-size: {{ settings.font_body_size }}px;
      --nexus-heading-weight: 900;

      /* ── M3 Shape System ── */
      --nexus-radius:    28px;
      --m3-radius-xl:    28px;
      --m3-radius-lg:    16px;
      --m3-radius-md:    12px;
      --m3-radius-sm:    8px;
      --m3-radius-full:  999px;

      /* ── M3 Glassmorphism ── */
      --nexus-glass:     rgba(28, 27, 31, 0.72);
      --nexus-glass-border: rgba(208, 188, 255, 0.08);

      /* ── M3 Elevation (tonal) ── */
      --m3-elevation-1:  0 1px 3px 1px rgba(0,0,0,.15), 0 1px 2px rgba(0,0,0,.3);
      --m3-elevation-2:  0 2px 6px 2px rgba(0,0,0,.15), 0 1px 2px rgba(0,0,0,.3);
      --m3-elevation-3:  0 4px 8px 3px rgba(0,0,0,.15), 0 1px 3px rgba(0,0,0,.3);
    }
  </style>
</head>

<body class="nexus-body template-{{ template.name | handle }}">

  {%- comment -%} ===== Skip to Content ===== {%- endcomment -%}
  <a class="nexus-skip-link" href="#MainContent">Skip to content</a>

  {%- comment -%} ===== Prototyper Sidebar ===== {%- endcomment -%}
  {% if settings.prototyper_enabled %}
    {% section 'prototyper-bar' %}
  {% endif %}

  {%- comment -%} ===== Header ===== {%- endcomment -%}
  {% section 'header' %}

  {%- comment -%} ===== Main Content ===== {%- endcomment -%}
  <main id="MainContent" class="nexus-main" role="main">
    {{ content_for_layout }}
  </main>

  {%- comment -%} ===== Designer Workbench Panel ===== {%- endcomment -%}
  {% if settings.workbench_enabled %}
    {% section 'designer-workbench' %}
  {% endif %}

  {%- comment -%} ===== Footer ===== {%- endcomment -%}
  {% section 'footer' %}

  {%- comment -%} ===== Theme JS ===== {%- endcomment -%}
  <script src="{{ 'nexus-core.js' | asset_url }}" defer></script>

</body>
</html>
